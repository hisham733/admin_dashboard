<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login — Orders Dashboard</title>
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --ink:   #0d0d14;
            --card:  #13131c;
            --card2: #1a1a26;
            --line:  #22223a;
            --gold:  #f5c842;
            --sky:   #4fc3f7;
            --coral: #ff6f61;
            --mint:  #56e39f;
            --text:  #e2e2f0;
            --muted: #6b6b8f;
        }
        * { margin:0; padding:0; box-sizing:border-box; }
        body {
            font-family:'Outfit',sans-serif;
            background:var(--ink);
            color:var(--text);
            min-height:100vh;
            display:flex;
            align-items:center;
            justify-content:center;
            overflow:hidden;
        }
        body::before {
            content:'';
            position:fixed;
            inset:0;
            background-image:
                linear-gradient(rgba(255,255,255,.015) 1px,transparent 1px),
                linear-gradient(90deg,rgba(255,255,255,.015) 1px,transparent 1px);
            background-size:44px 44px;
            pointer-events:none;
        }
        .orb1 {
            position:fixed;
            width:600px; height:600px;
            border-radius:50%;
            background:radial-gradient(circle,rgba(245,200,66,.06) 0%,transparent 70%);
            top:-100px; right:-100px;
            pointer-events:none;
        }
        .orb2 {
            position:fixed;
            width:400px; height:400px;
            border-radius:50%;
            background:radial-gradient(circle,rgba(79,195,247,.05) 0%,transparent 70%);
            bottom:-80px; left:-80px;
            pointer-events:none;
        }

        .wrap {
            width:100%;
            max-width:440px;
            padding:20px;
            animation:fadeUp .5s cubic-bezier(.34,1.3,.64,1) both;
        }
        @keyframes fadeUp {
            from{opacity:0;transform:translateY(24px);}
            to{opacity:1;transform:translateY(0);}
        }

        /* Brand */
        .brand { text-align:center; margin-bottom:28px; }
        .brand-icon {
            width:52px; height:52px;
            background:var(--gold);
            border-radius:14px;
            display:inline-flex; align-items:center; justify-content:center;
            font-size:24px; margin-bottom:12px;
            box-shadow:0 8px 28px rgba(245,200,66,.3);
            animation:fadeUp .5s .1s both;
        }
        .brand h1 {
            font-family:'Bebas Neue',sans-serif;
            font-size:36px; letter-spacing:2px;
            color:#fff; line-height:1;
            animation:fadeUp .5s .15s both;
        }
        .brand h1 em { color:var(--gold); font-style:normal; }
        .brand p { font-size:12px; color:var(--muted); margin-top:5px; animation:fadeUp .5s .2s both; }

        /* Card */
        .card {
            background:var(--card);
            border:1px solid var(--line);
            border-radius:18px;
            padding:32px;
            animation:fadeUp .5s .25s both;
        }
        .card-header {
            display:flex; align-items:center; justify-content:space-between;
            margin-bottom:24px;
        }
        .card-title { font-family:'Bebas Neue',sans-serif; font-size:22px; letter-spacing:1px; }

        .live-pill {
            display:inline-flex; align-items:center; gap:6px;
            padding:4px 12px; border-radius:20px; font-size:11px;
            background:rgba(86,227,159,.1);
            border:1px solid rgba(86,227,159,.25);
            color:var(--mint);
        }
        .live-dot {
            width:6px; height:6px; border-radius:50%;
            background:var(--mint); box-shadow:0 0 5px var(--mint);
            animation:pulse 1.6s infinite;
        }
        @keyframes pulse{0%,100%{opacity:1;}50%{opacity:.3;}}

        /* Alert */
        .alert {
            padding:10px 14px; border-radius:8px;
            font-size:12px; margin-bottom:16px;
            display:none; align-items:center; gap:8px;
        }
        .alert.error {
            background:rgba(255,111,97,.08);
            border:1px solid rgba(255,111,97,.25);
            color:var(--coral);
        }
        .alert.show { display:flex; }

        /* Form */
        .fg { display:flex; flex-direction:column; gap:5px; margin-bottom:16px; }
        .flabel { font-size:10px; text-transform:uppercase; letter-spacing:1.4px; color:var(--muted); }
        .input-wrap { position:relative; }
        .input-icon {
            position:absolute; left:13px; top:50%;
            transform:translateY(-50%);
            font-size:14px; color:var(--muted); pointer-events:none;
        }
        .finput {
            width:100%;
            padding:11px 13px 11px 40px;
            background:var(--card2);
            border:1px solid var(--line);
            border-radius:10px;
            color:var(--text);
            font-family:'Outfit',sans-serif;
            font-size:13px; outline:none;
            transition:border-color .2s, box-shadow .2s;
        }
        .finput:focus {
            border-color:var(--gold);
            box-shadow:0 0 0 3px rgba(245,200,66,.08);
        }
        .finput::placeholder { color:var(--muted); }
        .show-pass {
            position:absolute; right:12px; top:50%;
            transform:translateY(-50%);
            background:none; border:none;
            color:var(--muted); cursor:pointer;
            font-size:14px; padding:4px;
            transition:color .2s;
        }
        .show-pass:hover { color:var(--text); }

        .form-meta {
            display:flex; align-items:center;
            justify-content:space-between;
            margin-bottom:22px;
        }
        .remember { display:flex; align-items:center; gap:8px; cursor:pointer; }
        .remember input[type="checkbox"] { width:15px; height:15px; accent-color:var(--gold); cursor:pointer; }
        .remember span { font-size:12px; color:var(--muted); }
        .forgot { font-size:12px; color:var(--gold); text-decoration:none; transition:opacity .2s; }
        .forgot:hover { opacity:.7; }

        .btn-submit {
            width:100%; padding:13px;
            border-radius:10px; border:none;
            background:var(--gold); color:#0d0d14;
            font-family:'Bebas Neue',sans-serif;
            font-size:18px; letter-spacing:1px;
            cursor:pointer; transition:all .2s;
            display:flex; align-items:center;
            justify-content:center; gap:8px;
        }
        .btn-submit:hover {
            background:#d4b030;
            box-shadow:0 6px 20px rgba(245,200,66,.3);
            transform:translateY(-1px);
        }
        .btn-submit:active { transform:translateY(0); }

        .card-footer {
            text-align:center; margin-top:20px;
            font-size:12px; color:var(--muted);
            animation:fadeUp .5s .3s both;
        }
        .card-footer a {
            color:var(--gold); text-decoration:none;
            font-weight:600; transition:opacity .2s;
        }
        .card-footer a:hover { opacity:.7; }

        ::-webkit-scrollbar{width:4px;}
        ::-webkit-scrollbar-track{background:var(--ink);}
        ::-webkit-scrollbar-thumb{background:var(--line);border-radius:2px;}
    </style>
</head>
<body>

<div class="orb1"></div>
<div class="orb2"></div>

<div class="wrap">

    <div class="brand">
        <div class="brand-icon">📦</div>
        <h1>Orders <em>Dashboard</em></h1>
        <p>Sign in to manage your orders</p>
    </div>

    <div class="card">
        <div class="card-header">
            <span class="card-title">Welcome Back</span>
            <span class="live-pill">
                <span class="live-dot"></span>
                Secure
            </span>
        </div>

        <!-- Server-side error -->
        <% if (typeof error !== 'undefined' && error) { %>
        <div class="alert error show">⚠️ <%= error %></div>
        <% } %>

        <form action="/" method="POST">

            <div class="fg">
                <label class="flabel">Email</label>
                <div class="input-wrap">
                    <span class="input-icon">✉</span>
                    <input class="finput" type="email" name="email"
                        placeholder="you@example.com"
                        autocomplete="username" required>
                </div>
            </div>

            <div class="fg">
                <label class="flabel">Password</label>
                <div class="input-wrap">
                    <span class="input-icon">🔒</span>
                    <input class="finput" type="password" name="password"
                        id="passInput" placeholder="••••••••"
                        autocomplete="current-password" required>
                    <button type="button" class="show-pass" onclick="togglePass()" id="eyeBtn">👁</button>
                </div>
            </div>
            <button type="submit" class="btn-submit">
                Sign In →
            </button>

        </form>
    </div>

    <div class="card-footer">
        Don't have an account? <a href="/register">Create one</a>
    </div>

</div>

<script>
    function togglePass() {
        var input = document.getElementById('passInput');
        var btn   = document.getElementById('eyeBtn');
        input.type = input.type === 'password' ? 'text' : 'password';
        btn.textContent = input.type === 'password' ? '👁' : '🙈';
    }
</script>

</body>
</html>
