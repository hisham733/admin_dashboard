<!DOCTYPE html>
<html lang="en">
<head>
  <script>
    (function(){
      var t=localStorage.getItem('theme')||'light';
      if(t==='system')t=window.matchMedia('(prefers-color-scheme:dark)').matches?'dark':'light';
      document.documentElement.setAttribute('data-theme',t);
    })();
  </script>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Error <%= typeof status !== 'undefined' ? status : '' %> — Admin Console</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/theme.css">
  <% if (typeof ui !== 'undefined' && ui && ui.primaryColor) { %>
  <style>:root,[data-theme="light"],[data-theme="dark"]{--accent:<%= ui.primaryColor %>;--accent-hover:<%= ui.primaryColor %>dd;}</style>
  <% } %>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
      background: var(--surface-secondary);
      color: var(--text-primary);
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 24px;
    }
    .error-page {
      width: 100%;
      max-width: 520px;
      text-align: center;
    }
    .error-code {
      font-size: clamp(72px, 20vw, 140px);
      font-weight: 800;
      line-height: 1;
      color: var(--accent);
      opacity: 0.9;
      letter-spacing: -4px;
      margin-bottom: 8px;
    }
    .error-label {
      font-size: 14px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 1.5px;
      color: var(--text-muted);
      margin-bottom: 24px;
    }
    .error-card {
      background: var(--surface-primary);
      border: 1px solid var(--border-default);
      border-radius: var(--radius-lg);
      padding: 32px 28px;
      box-shadow: var(--shadow-md);
      margin-bottom: 24px;
      text-align: left;
    }
    .error-message {
      font-size: 15px;
      line-height: 1.6;
      color: var(--text-secondary);
      word-break: break-word;
    }
    .error-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      justify-content: center;
      margin-top: 8px;
    }
    .error-actions .btn {
      text-decoration: none;
      padding: 10px 20px;
      font-size: 14px;
      font-weight: 600;
      border-radius: var(--radius-md);
      transition: all 0.2s;
      display: inline-flex;
      align-items: center;
      gap: 8px;
    }
    .error-actions .btn-primary {
      background: var(--accent);
      color: white;
      border: 1px solid var(--accent);
    }
    .error-actions .btn-primary:hover {
      background: var(--accent-hover);
      border-color: var(--accent-hover);
      transform: translateY(-1px);
    }
    .error-actions .btn-secondary {
      background: var(--surface-primary);
      color: var(--text-secondary);
      border: 1px solid var(--border-default);
    }
    .error-actions .btn-secondary:hover {
      background: var(--surface-tertiary);
      color: var(--text-primary);
    }
  </style>
</head>
<body>

<div class="error-page">
  <div class="error-code"><%= typeof status !== 'undefined' ? status : 'Error' %></div>
  <div class="error-label"><%= typeof label !== 'undefined' ? label : 'Something went wrong' %></div>

  <div class="error-card">
    <p class="error-message"><%= typeof message !== 'undefined' ? message : 'An unexpected error occurred. Please try again.' %></p>
  </div>

  <div class="error-actions">
    <a href="javascript:history.back()" class="btn btn-secondary">← Go Back</a>
    <a href="/dashboard" class="btn btn-primary">Dashboard →</a>
  </div>
</div>

</body>
</html>
