<div class="section-header">
  <div>
    <a href="/role" class="btn btn-ghost btn-sm" style="margin-bottom: 8px;">← Back to Roles</a>
    <h1 class="page-title">Add New Role</h1>
    <p class="page-subtitle">Create a role and assign permissions by resource.</p>
  </div>
</div>

<div class="card">
  <div class="card-body">
    <% if (typeof error !== 'undefined' && error) { %>
      <div class="alert-inline alert-error"><%= error %></div>
    <% } %>
    
    <form action="/role" method="POST" id="roleForm">
      <div class="form-group">
        <label class="form-label">Role Name</label>
        <div class="input-wrap">
          <span class="input-icon">🛡️</span>
          <input type="text" name="name" class="form-input" placeholder="e.g. Editor, Manager" required>
        </div>
      </div>
      <div class="form-group">
        <label class="form-label">Permissions</label>
        <p class="form-hint">Click a section to expand. Use "Select all" to grant every action for that resource. Where a resource has <strong>List</strong>, select List before View, Create, Update, or Delete.</p>
        <div id="perm-list-hint" class="alert-inline alert-error" style="display: none; margin-top: 8px;" role="alert"></div>
        <div class="permission-groups">
          <% 
            var resLabels = { dashboard: 'Dashboard', form: 'Forms', permissions: 'Permissions', role: 'Roles', settings: 'Settings', user: 'Users' };
            var actionLabels = { list: 'List', view: 'View', create: 'Create', update: 'Update', delete: 'Delete' };
            var grouped = {};
            (typeof permissions !== 'undefined' ? permissions : []).forEach(function(p) {
              var parts = p.name.split(':');
              var res = parts[0] || 'other';
              if (!grouped[res]) grouped[res] = [];
              grouped[res].push({ id: p.id, name: p.name, actionLabel: actionLabels[parts[1]] || parts[1] });
            });
            var groupOrder = ['dashboard', 'user', 'role', 'permissions', 'form', 'settings'];
            groupOrder.forEach(function(resKey) {
              var items = grouped[resKey];
              if (!items || !items.length) return;
              var safeId = resKey.replace(/[^a-z0-9]/g, '_');
          %>
          <div class="permission-group" data-group="<%= safeId %>">
            <div class="permission-group-header" onclick="toggleGroup('<%= safeId %>')">
              <span class="permission-group-title"><%= resLabels[resKey] || resKey %></span>
              <button type="button" class="permission-group-toggle" onclick="event.stopPropagation(); selectAllInGroup('<%= safeId %>', true)">Select all</button>
            </div>
            <div class="permission-group-body" id="body-<%= safeId %>">
              <% items.forEach(function(p) { %>
                <label class="permission-check-item">
                  <input type="checkbox" name="permissionIds" value="<%= p.id %>" class="perm-cb" data-group="<%= safeId %>" data-perm-name="<%= p.name %>">
                  <span><%= p.actionLabel %></span>
                </label>
              <% }); %>
            </div>
          </div>
          <% }); %>
        </div>
      </div>
      <div style="display: flex; gap: 12px; margin-top: 24px;">
        <button type="submit" class="btn btn-primary">Create Role</button>
        <a href="/role" class="btn btn-secondary">Cancel</a>
      </div>
    </form>
  </div>
</div>

<script>
(function() {
  var LIST_FIRST_MSG = 'Select the List permission for this resource first (e.g. User List before User View). List only applies together with other actions under the same resource.';
  function toggleGroup(id) {
    var el = document.getElementById('body-' + id);
    if (el) el.classList.toggle('collapsed');
  }
  /** Resource key: part before ":" in "resource:action" (same resource = same rule scope). */
  function resourceFromPermName(name) {
    var i = String(name).indexOf(':');
    return i === -1 ? String(name) : String(name).slice(0, i);
  }
  function actionFromPermName(name) {
    var i = String(name).indexOf(':');
    return i === -1 ? '' : String(name).slice(i + 1);
  }
  function findListCheckboxForResource(resource) {
    var cbs = document.querySelectorAll('.perm-cb[data-perm-name]');
    for (var i = 0; i < cbs.length; i++) {
      var n = cbs[i].getAttribute('data-perm-name') || '';
      if (resourceFromPermName(n) === resource && actionFromPermName(n) === 'list') return cbs[i];
    }
    return null;
  }
  function forEachCheckboxSameResource(resource, fn) {
    document.querySelectorAll('.perm-cb[data-perm-name]').forEach(function(cb) {
      var n = cb.getAttribute('data-perm-name') || '';
      if (resourceFromPermName(n) === resource) fn(cb, n);
    });
  }
  function showListHint() {
    var el = document.getElementById('perm-list-hint');
    if (el) {
      el.textContent = LIST_FIRST_MSG;
      el.style.display = 'block';
    }
  }
  function hideListHint() {
    var el = document.getElementById('perm-list-hint');
    if (el) el.style.display = 'none';
  }
  function selectAllInGroup(id, checked) {
    document.querySelectorAll('.perm-cb[data-group="' + id + '"]').forEach(function(cb) { cb.checked = checked; });
    hideListHint();
  }
  function bindListFirstRules() {
    document.querySelectorAll('.perm-cb').forEach(function(cb) {
      cb.addEventListener('change', function() {
        var name = cb.getAttribute('data-perm-name') || '';
        var resource = resourceFromPermName(name);
        var action = actionFromPermName(name);
        var listCb = findListCheckboxForResource(resource);
        if (!listCb) return;
        if (action === 'list' && !cb.checked) {
          forEachCheckboxSameResource(resource, function(other) {
            var oa = actionFromPermName(other.getAttribute('data-perm-name') || '');
            if (oa !== 'list') other.checked = false;
          });
          hideListHint();
          return;
        }
        if (action !== 'list' && cb.checked && !listCb.checked) {
          cb.checked = false;
          showListHint();
        }
      });
    });
    var form = document.getElementById('roleForm');
    if (form) {
      form.addEventListener('submit', function(e) {
        var ok = true;
        document.querySelectorAll('.perm-cb[data-perm-name]').forEach(function(cb) {
          if (!cb.checked) return;
          var n = cb.getAttribute('data-perm-name') || '';
          var action = actionFromPermName(n);
          var resource = resourceFromPermName(n);
          var listCb = findListCheckboxForResource(resource);
          if (listCb && action !== 'list' && !listCb.checked) ok = false;
        });
        if (!ok) {
          e.preventDefault();
          showListHint();
        }
      });
    }
  }
  window.toggleGroup = toggleGroup;
  window.selectAllInGroup = selectAllInGroup;
  bindListFirstRules();
})();
</script>
