<%
  var _q = typeof query !== 'undefined' ? query : {};
  var _rolePerms = (typeof user !== 'undefined' && user && user.permissions) ? user.permissions : [];
  var _isSuperAdmin = typeof user !== 'undefined' && user && user.role && user.role.name === 'super admin';
  var _canCreateRole = _isSuperAdmin || _rolePerms.includes('role:create');
  var _canEditRole   = _isSuperAdmin || _rolePerms.includes('role:update');
  var _canDeleteRole = _isSuperAdmin || _rolePerms.includes('role:delete');
  var _sortField = (_q.sort) ? _q.sort.split(':')[0] : '';
  var _sortDir   = (_q.sort) ? (_q.sort.split(':')[1] || 'asc') : 'asc';
  function _sortUrl(field) {
    var dir = (_sortField === field && _sortDir === 'asc') ? 'desc' : 'asc';
    var nq = Object.assign({}, _q, { sort: field+':'+dir, page: 1 });
    return '/role?' + Object.keys(nq).filter(function(k){ return nq[k]; }).map(function(k){ return k+'='+encodeURIComponent(nq[k]); }).join('&');
  }
  function _sortIcon(field) { return _sortField === field ? (_sortDir === 'asc' ? ' ↑' : ' ↓') : ''; }
%>
<div class="section-header">
  <div>
    <h1 class="page-title">Role Management</h1>
    <p class="page-subtitle">Define access levels and permission scopes for your organization.</p>
  </div>
  <% if (_canCreateRole) { %>
    <a href="/role/create" class="btn btn-primary">+ Add New Role</a>
  <% } %>
</div>

<div class="stat-cards">
  <div class="stat-card">
    <div class="stat-card-label">Total Roles</div>
    <div class="stat-card-value"><%= typeof total !== 'undefined' ? total : (typeof roles !== 'undefined' && roles ? roles.length : 0) %></div>
    <div class="stat-card-sub">Role types</div>
  </div>
  <div class="stat-card">
    <div class="stat-card-label">Active Users</div>
    <div class="stat-card-value"><%= typeof userCount !== 'undefined' ? userCount : 0 %></div>
    <div class="stat-card-sub">Platform members</div>
  </div>
  <div class="stat-card">
    <div class="stat-card-label">Permissions Assigned</div>
    <div class="stat-card-value"><%= typeof permissionCount !== 'undefined' ? permissionCount : 0 %></div>
    <div class="stat-card-sub">Total permissions</div>
  </div>
</div>

<div class="card">
  <div class="card-header" style="display:flex; align-items:center; gap:12px; flex-wrap:wrap;">
    <form method="GET" action="/role" style="display:flex; gap:8px; align-items:center;">
      <div class="search-input" style="max-width:280px;">
        <span class="search-input-icon">🔍</span>
        <input type="text" name="search" placeholder="Search roles…" value="<%= _q.search || '' %>">
      </div>
      <% if (_q.sort) { %><input type="hidden" name="sort" value="<%= _q.sort %>"><% } %>
      <button type="submit" class="btn btn-ghost btn-sm">Search</button>
      <% if (_q.search || _q.sort) { %><a href="/role" class="btn btn-ghost btn-sm">Clear</a><% } %>
    </form>
  </div>
  <div class="table-wrap">
    <table class="table">
      <thead>
        <tr>
          <th><a href="<%= _sortUrl('name') %>" style="color:inherit;text-decoration:none;">Role Name<%= _sortIcon('name') %></a></th>
          <th>Permissions</th>
          <th>Assigned To</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% if (typeof roles !== 'undefined' && roles && roles.length) { %>
          <% 
          const roleColors = ['#ef4444', '#f97316', '#22c55e', '#94a3b8'];
          roles.forEach(function(r, i) { 
            const color = roleColors[i % roleColors.length];
          %>
            <tr>
              <td>
                <div style="display: flex; align-items: center; gap: 10px;">
                  <span style="width: 8px; height: 8px; border-radius: 50%; background: <%= color %>;"></span>
                  <strong><%= r.name %></strong>
                </div>
              </td>
              <td>
                <div class="role-permission-summary">
                  <% if (r.permissions && r.permissions.length) { %>
                    <% 
                      var resLabels = { dashboard: 'Dashboard', form: 'Forms', permissions: 'Permissions', role: 'Roles', settings: 'Settings', user: 'Users' };
                      var byResource = {};
                      r.permissions.forEach(function(p) {
                        var res = (p.name && p.name.split(':')[0]) || 'other';
                        if (!byResource[res]) byResource[res] = true;
                      });
                      var order = ['dashboard', 'user', 'role', 'permissions', 'form', 'settings'];
                    %>
                    <% order.forEach(function(resKey) { %>
                      <% if (byResource[resKey]) { %>
                        <span class="role-permission-tag"><%= resLabels[resKey] || resKey %></span>
                      <% } %>
                    <% }); %>
                  <% } else { %>
                    <span class="text-muted">None</span>
                  <% } %>
                </div>
              </td>
              <td>
                <% const count = r._count && r._count.users ? r._count.users : 0; %>
                <% if (count > 0) { %>
                  <span style="font-weight: 600; color: var(--text-primary);"><%= count %> user<%= count !== 1 ? 's' : '' %></span>
                <% } else { %>
                  <span style="color: var(--text-muted);">0 users</span>
                <% } %>
              </td>
              <td>
                <div class="table-actions">
                  <% if (_canEditRole) { %>
                    <a href="/role/<%= r.id %>/edit" class="btn btn-ghost btn-icon btn-sm" title="Edit">✏️</a>
                  <% } %>
                  <% if (_canDeleteRole) { %>
                    <% if (count === 0) { %>
                      <form action="/role/<%= r.id %>" method="POST" style="display:inline;"
                        data-confirm="Delete role &quot;<%= r.name %>&quot;? This cannot be undone."
                        data-confirm-title="Delete Role"
                        data-confirm-ok="Delete"
                        data-confirm-danger>
                        <input type="hidden" name="_method" value="DELETE">
                        <button type="submit" class="btn btn-ghost btn-icon btn-sm" title="Delete">🗑️</button>
                      </form>
                    <% } else { %>
                      <button type="button" class="btn btn-ghost btn-icon btn-sm" title="Cannot delete — assigned to users" disabled>🗑️</button>
                    <% } %>
                  <% } %>
                </div>
              </td>
            </tr>
          <% }); %>
        <% } else { %>
          <tr>
            <td colspan="4">
              <div class="empty-state">
                <div class="empty-state-icon">🛡️</div>
                <div class="empty-state-title">No roles yet</div>
                <div class="empty-state-text">Create your first role to define access levels.</div>
              </div>
            </td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>
  <%- include('../partials/pagination', { page: page, perPage: perPage, total: total, query: query, baseUrl: '/role' }) %>
</div>
