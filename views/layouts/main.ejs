<!DOCTYPE html>
<html lang="en">
<head>
  <script>
    (function(){
      var def='<%= typeof ui !== "undefined" && ui.theme ? ui.theme : "light" %>';
      var t=localStorage.getItem('theme')||def;
      if(t==='system')t=window.matchMedia('(prefers-color-scheme:dark)').matches?'dark':'light';
      document.documentElement.setAttribute('data-theme',t);
    })();
  </script>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title : 'Admin Console' %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/theme.css">
  <link rel="stylesheet" href="/css/components.css">
  <% if (typeof ui !== 'undefined' && ui.primaryColor) { %>
  <style>:root, [data-theme="light"], [data-theme="dark"] { --accent: <%= ui.primaryColor %>; --accent-hover: <%= ui.primaryColor %>dd; }</style>
  <% } %>
</head>
<body>
  <% if (typeof toastError !== 'undefined' && toastError) { %>
  <div class="toast toast-error" id="toastError" role="alert"><%= toastError %></div>
  <% } %>
  <% if (typeof toastSuccess !== 'undefined' && toastSuccess) { %>
  <div class="toast toast-success" id="toastSuccess" role="alert"><%= toastSuccess %></div>
  <% } %>
  <div class="app-layout">
    <%- include('../partials/sidebar') %>
    <div class="main-wrapper" id="mainWrapper">
      <%- include('../partials/header') %>
      <main class="main-content">
        <% if (typeof contentPartial !== 'undefined') { %>
          <%- include('../' + contentPartial, typeof contentData !== 'undefined' ? contentData : {}) %>
        <% } else if (typeof body !== 'undefined') { %>
          <%- body %>
        <% } %>
      </main>
    </div>
  </div>
  <script>
    (function() {
      var themeKey='theme';
      var toggle=document.getElementById('themeToggle');
      var iconLight=document.getElementById('themeIconLight');
      var iconDark=document.getElementById('themeIconDark');
      var themeLabel=document.getElementById('themeLabel');
      function applyTheme(t){
        var actual=t;
        if(t==='system')actual=window.matchMedia('(prefers-color-scheme:dark)').matches?'dark':'light';
        document.documentElement.setAttribute('data-theme',actual);
        localStorage.setItem(themeKey,t);
        if(iconLight)iconLight.style.display=actual==='dark'?'inline-block':'none';
        if(iconDark)iconDark.style.display=actual==='dark'?'none':'inline-block';
        if(themeLabel)themeLabel.textContent=actual==='dark'?'Dark':'Light';
      }
      if(toggle){
        toggle.addEventListener('click',function(){
          var cur=localStorage.getItem(themeKey)||'light';
          applyTheme(cur==='dark'?'light':'dark');
        });
        applyTheme(localStorage.getItem(themeKey)||'light');
      }
      var profileTrigger=document.getElementById('profileDropdownTrigger');
      var profileDropdown=profileTrigger?profileTrigger.closest('.profile-dropdown'):null;
      var profileMenu=document.getElementById('profileDropdownMenu');
      if(profileTrigger&&profileDropdown){
        profileTrigger.addEventListener('click',function(e){
          e.stopPropagation();
          profileDropdown.classList.toggle('open');
          profileTrigger.setAttribute('aria-expanded',profileDropdown.classList.contains('open'));
        });
        document.addEventListener('click',function(){
          profileDropdown.classList.remove('open');
          profileTrigger.setAttribute('aria-expanded','false');
        });
        if(profileMenu)profileMenu.addEventListener('click',function(e){e.stopPropagation();});
      }
      var overlay=document.getElementById('sidebarOverlay');
      var sidebar=document.getElementById('sidebar');
      var mainWrapper=document.getElementById('mainWrapper');
      var sidebarKey='sidebarCollapsed';
      var sidebarToggleCollapse=document.getElementById('sidebarToggleCollapse');
      var sidebarToggleExpand=document.getElementById('sidebarToggleExpand');
      function applySidebar(collapsed){
        if(sidebar)sidebar.classList.toggle('sidebar--collapsed',collapsed);
        if(mainWrapper)mainWrapper.classList.toggle('main-wrapper--sidebar-collapsed',collapsed);
        if(sidebarToggleCollapse)sidebarToggleCollapse.style.display=collapsed?'none':'inline-block';
        if(sidebarToggleExpand)sidebarToggleExpand.style.display=collapsed?'inline-block':'none';
        try{localStorage.setItem(sidebarKey,collapsed?'1':'0');}catch(e){}
      }
      var sidebarToggle=document.getElementById('sidebarToggle');
      if(sidebarToggle){
        sidebarToggle.addEventListener('click',function(){
          var collapsed=sidebar&&sidebar.classList.contains('sidebar--collapsed');
          if(window.innerWidth<=768){
            sidebar.classList.add('open');
            overlay.classList.add('open');
          }else{
            applySidebar(!collapsed);
          }
        });
        var stored=localStorage.getItem(sidebarKey);
        if(window.innerWidth>768){
          if(stored==='1')applySidebar(true);
          else if(sidebarToggleExpand)sidebarToggleExpand.style.display='none';
        }
      }
      if(overlay){
        overlay.addEventListener('click',function(){
          if(sidebar)sidebar.classList.remove('open');
          overlay.classList.remove('open');
        });
      }
      (function(){
        var t=document.getElementById('toastError')||document.getElementById('toastSuccess');
        if(t){
          setTimeout(function(){
            t.style.opacity='0';
            t.style.transform='translateY(-12px)';
            t.style.transition='opacity 0.25s, transform 0.25s';
            setTimeout(function(){
              if(window.history.replaceState&&window.location.search){
                var u=new URL(window.location.href);
                u.searchParams.delete('error');
                u.searchParams.delete('success');
                window.history.replaceState({},'',u.toString());
              }
              t.remove();
            },280);
          },4500);
        }
      })();
    })();
  </script>
  <% if (typeof scripts !== 'undefined') { %><%- scripts %><% } %>
</body>
</html>
