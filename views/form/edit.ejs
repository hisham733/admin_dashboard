<div class="form-builder-page">
  <div class="section-header">
    <div>
      <a href="/form" class="btn btn-ghost btn-sm" style="margin-bottom: 8px;">← Back to Forms</a>
      <h1 class="page-title">Edit: <%= form.name %></h1>
      <p class="page-subtitle">Update your form template. <% if (form.isActive) { %><span class="badge badge-success">Active</span><% } else { %><span class="badge badge-muted">Inactive</span><% } %></p>
    </div>
  </div>

  <% if (typeof error !== 'undefined' && error) { %>
    <div class="alert-inline alert-error"><%= error %></div>
  <% } %>

  <div class="form-builder-with-preview">
    <div class="form-builder-column">
    <div class="card form-builder-card">
  <div class="card-body">
    <div class="form-builder-section">
      <label class="form-builder-label">Template Info</label>
      <div class="form-group">
        <label class="form-label">Template Name</label>
        <input type="text" class="form-input" id="templateName" value="<%= form.name %>" placeholder="e.g. Print Order Form">
      </div>
    </div>

    <div class="form-builder-section">
      <label class="form-builder-label">Fields & Groups <span class="badge badge-muted" id="fieldCount">0</span></label>
      <div class="alert-inline alert-error" id="alertBox" style="display:none;"></div>
      <div class="empty-state form-builder-empty" id="emptyState">
        <div class="empty-state-icon">📋</div>
        <p class="empty-state-text">No fields yet — add a <strong>Group</strong> or <strong>Field</strong> to start</p>
      </div>
      <div class="form-builder-fields" id="fieldsList"></div>
      <div style="display:flex;gap:8px;flex-wrap:wrap;">
        <button type="button" class="btn btn-ghost form-builder-add" onclick="addGroup()">
          <span class="form-builder-add-icon">+</span> Add Group
        </button>
        <button type="button" class="btn btn-ghost form-builder-add" onclick="addField()">
          <span class="form-builder-add-icon">+</span> Add Field
        </button>
      </div>
    </div>

    <div class="form-builder-submit">
      <div class="form-builder-submit-info">
        <strong>Ready to save?</strong>
        Click Save Template to update
      </div>
      <div style="display:flex;gap:10px;flex-wrap:wrap;align-items:center;">
        <a href="/form/<%= form.id %>" class="btn btn-secondary">Cancel</a>
        <button type="button" class="btn btn-primary" onclick="submitTemplate()">Save Template →</button>
        <% if (typeof canActivate !== 'undefined' && canActivate) { %>
          <% if (form.isActive) { %>
            <form action="/form/<%= form.id %>/deactivate" method="POST" style="display:inline;"
              data-confirm="Deactivate &quot;<%= form.name %>&quot;? No form will be active after this."
              data-confirm-title="Deactivate Form"
              data-confirm-ok="Deactivate">
              <button type="submit" class="btn btn-ghost" style="color: var(--warning, #f59e0b);">Deactivate</button>
            </form>
          <% } else { %>
            <form action="/form/<%= form.id %>/activate" method="POST" style="display:inline;"
              data-confirm="Set &quot;<%= form.name %>&quot; as the active form? The current active form will be deactivated."
              data-confirm-title="Activate Form"
              data-confirm-ok="Activate">
              <button type="submit" class="btn btn-ghost" style="color: var(--success);">Activate</button>
            </form>
          <% } %>
        <% } %>
      </div>
    </div>
  </div>
</div>
  </div>

  <%- include('../partials/form-live-preview') %>
</div>
</div>

<style>
.form-builder-card .card-body { max-width: 900px; }
.form-builder-section { margin-bottom: 28px; }
.form-builder-label { font-size: 12px; font-weight: 700; letter-spacing: 0.05em; color: var(--text-muted); text-transform: uppercase; display: flex; align-items: center; gap: 8px; margin-bottom: 14px; }
.form-builder-fields { display: flex; flex-direction: column; gap: 12px; margin-bottom: 16px; }
.form-builder-add { padding: 12px 20px; border: 1px dashed var(--border-default); border-radius: var(--radius-md); color: var(--accent); font-weight: 600; display: inline-flex; align-items: center; gap: 8px; }
.form-builder-add:hover { background: var(--accent-muted); border-color: var(--accent); border-style: solid; }
.form-builder-add-icon { width: 20px; height: 20px; border-radius: 6px; background: var(--accent); color: white; display: inline-flex; align-items: center; justify-content: center; font-size: 14px; }
.form-builder-empty { padding: 24px; margin-bottom: 12px; display: none; }
.form-builder-empty.show { display: block; }
.form-builder-group { border: 1px solid var(--border-default); border-radius: var(--radius-md); overflow: hidden; background: var(--surface-secondary); }
.form-builder-group-header { padding: 12px 16px; background: var(--surface-primary); border-bottom: 1px solid var(--border-default); display: flex; align-items: center; gap: 12px; }
.form-builder-group-header input { flex: 1; }
.form-builder-group-fields { padding: 12px; display: flex; flex-direction: column; gap: 10px; }
.form-builder-group-add { margin-top: 8px; }
.form-builder-field-row { display: grid; grid-template-columns: 1fr 160px 140px 40px; gap: 12px; align-items: end; padding: 16px; background: var(--surface-secondary); border: 1px solid var(--border-default); border-radius: var(--radius-md); border-left: 3px solid var(--accent); }
.form-builder-field-row.form-builder-field-options { grid-template-columns: 1fr; }
.form-builder-field-row.form-builder-field-options .field-main { display: grid; grid-template-columns: 1fr 160px 140px 40px; gap: 12px; align-items: end; }
.form-builder-field-row.form-builder-field-options .field-options-extra { grid-column: 1; margin-top: 12px; padding-top: 12px; border-top: 1px solid var(--border-default); display: grid; gap: 12px; }
.opts-list { display: flex; flex-direction: column; gap: 8px; }
.opts-row { display: flex; gap: 8px; align-items: center; }
.opts-row .opts-item { flex: 1; }
.opts-remove { width: 36px; height: 36px; border-radius: var(--radius-sm); background: var(--error-muted); border: 1px solid var(--error); color: var(--error); cursor: pointer; flex-shrink: 0; }
.opts-remove:hover { background: var(--error); color: white; }
@media (max-width: 700px) { .form-builder-field-row { grid-template-columns: 1fr 1fr; grid-template-rows: auto auto; }
  .form-builder-field-row .fg:first-child { grid-column: span 2; }
  .form-builder-field-row .del-btn { grid-column: 2; grid-row: 2; justify-self: end; }
  .form-builder-field-row.form-builder-field-options .field-main { grid-template-columns: 1fr 1fr; } }
.form-builder-field-row .fg { display: flex; flex-direction: column; gap: 4px; }
.form-builder-field-row .flabel { font-size: 11px; text-transform: uppercase; letter-spacing: 0.5px; color: var(--text-muted); }
.form-builder-field-row .finput, .form-builder-field-row .fselect, .form-builder-field-row textarea.finput { width: 100%; padding: 8px 12px; font-size: 13px; border: 1px solid var(--border-default); border-radius: var(--radius-sm); background: var(--surface-primary); color: var(--text-primary); }
.form-builder-field-row textarea.finput { resize: vertical; min-height: 50px; }
.form-builder-field-row .radio-group { display: flex; gap: 8px; }
.form-builder-field-row .radio-opt { flex: 1; position: relative; }
.form-builder-field-row .radio-opt input { position: absolute; opacity: 0; width: 100%; height: 100%; top: 0; left: 0; margin: 0; cursor: pointer; }
.form-builder-field-row .radio-opt label { display: flex; align-items: center; justify-content: center; padding: 8px; background: var(--surface-primary); border: 1px solid var(--border-default); border-radius: var(--radius-sm); cursor: pointer; font-size: 12px; }
.form-builder-field-row .radio-opt input:checked + label { border-color: var(--accent); background: var(--accent-muted); color: var(--accent); }
.form-builder-field-row .del-btn { width: 40px; height: 40px; border-radius: var(--radius-sm); background: var(--error-muted); border: 1px solid var(--error); color: var(--error); cursor: pointer; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.form-builder-field-row .del-btn:hover { background: var(--error); color: white; }
.form-builder-submit { display: flex; align-items: center; justify-content: space-between; gap: 14px; flex-wrap: wrap; padding-top: 20px; border-top: 1px solid var(--border-default); margin-top: 8px; }
.form-builder-submit-info { font-size: 13px; color: var(--text-muted); }
.form-builder-submit-info strong { color: var(--text-primary); display: block; margin-bottom: 2px; }

.form-builder-page .section-header { margin-bottom: 20px; }
</style>

<script>
var formId = '<%= form.id %>';
var fields = [];
var idCounter = 0;
var TYPE_TO_HTML = { string: 'text', number: 'number', email: 'email', phone: 'tel', date: 'date', textarea: 'textarea', options: 'checkbox', radio: 'radio' };
var TYPES = [
  { value: 'string', label: 'Short text' },
  { value: 'number', label: 'Number' },
  { value: 'email', label: 'Email' },
  { value: 'phone', label: 'Phone' },
  { value: 'date', label: 'Date' },
  { value: 'textarea', label: 'Paragraph' },
  { value: 'options', label: 'Choose from list' },
  { value: 'radio', label: 'Single choice' }
];
function isGroup(it) { return it && Array.isArray(it.fields); }
function isField(it) { return it && 'type' in it; }
<% if (form.fields && Array.isArray(form.fields) && form.fields.length) { %>
(function() {
  var raw = <%- JSON.stringify(form.fields) %>;
  raw.forEach(function(it) {
    if (Array.isArray(it.fields)) {
      var maxId = 0;
      (it.fields || []).forEach(function(f) { if (typeof f.id === 'number' && f.id > maxId) maxId = f.id; });
      idCounter = Math.max(idCounter, maxId);
      fields.push({ id: it.id, name: it.name || '', order: it.order ?? fields.length, fields: (it.fields || []).map(function(f) {
        return { id: f.id, name: f.name || '', type: f.type || 'string', is_required: f.is_required !== false, options: Array.isArray(f.options) ? f.options.slice() : [], default_option: (f.default_option && String(f.default_option).trim()) || null };
      }) });
    } else {
      if (typeof it.id === 'number' && it.id > idCounter) idCounter = it.id;
      fields.push({ id: it.id, name: it.name || '', type: it.type || 'string', is_required: it.is_required !== false, options: Array.isArray(it.options) ? it.options.slice() : [], default_option: (it.default_option && String(it.default_option).trim()) || null });
    }
  });
  idCounter = (idCounter || 0) + 1;
})();
<% } %>
function totalCount() {
  var n = 0;
  fields.forEach(function(it) {
    if (isGroup(it)) n += (it.fields || []).length;
    else n += 1;
  });
  return n;
}
function addGroup() {
  var id = 'grp_' + (++idCounter);
  fields.push({ id: id, name: '', order: fields.length, fields: [] });
  renderFields();
  setTimeout(function() {
    var el = document.getElementById('group-' + id);
    if (el) el.scrollIntoView({ behavior: 'smooth', block: 'center' });
  }, 50);
}
function addField(grpId) {
  var id = ++idCounter;
  if (grpId) {
    var g = fields.find(function(x) { return x.id === grpId; });
    if (g) {
      g.fields = g.fields || [];
      g.fields.push({ id: id, name: '', type: 'string', is_required: true });
    }
  } else {
    fields.push({ id: id, name: '', type: 'string', is_required: true });
  }
  renderFields();
  setTimeout(function() {
    var el = document.getElementById('field-' + id);
    if (el) el.scrollIntoView({ behavior: 'smooth', block: 'center' });
  }, 50);
}
function removeGroup(id) {
  fields = fields.filter(function(f) { return !isGroup(f) || f.id !== id; });
  renderFields();
}
function removeField(id, grpId) {
  if (grpId) {
    var g = fields.find(function(x) { return x.id === grpId; });
    if (g && g.fields) g.fields = g.fields.filter(function(f) { return f.id !== id; });
  } else {
    fields = fields.filter(function(f) { return !isField(f) || f.id !== id; });
  }
  renderFields();
}
function updateGroup(id, key, value) {
  var g = fields.find(function(x) { return isGroup(x) && x.id === id; });
  if (g) g[key] = value;
  updatePreview();
}
function updateField(id, key, value, grpId) {
  var f;
  if (grpId) {
    var g = fields.find(function(x) { return x.id === grpId; });
    f = g && g.fields ? g.fields.find(function(x) { return x.id === id; }) : null;
  } else {
    f = fields.find(function(x) { return isField(x) && x.id === id; });
  }
  if (f) f[key] = value;
  updatePreview();
}
function buildFieldSchemaForPreview() {
  collectFromDom();
  return fields.map(function(it) {
    if (isGroup(it)) {
      return {
        id: it.id,
        name: it.name,
        order: it.order,
        fields: (it.fields || []).map(function(f) {
          var base = { id: f.id, name: f.name, type: f.type || 'string', htmlType: TYPE_TO_HTML[f.type || 'string'] || 'text', is_required: f.is_required !== false };
          if (f.type === 'options' || f.type === 'radio') {
            base.options = Array.isArray(f.options) ? f.options.filter(Boolean) : [];
            base.default_option = (f.default_option && String(f.default_option).trim()) || null;
          }
          return base;
        })
      };
    } else {
      var base = { id: it.id, name: it.name, type: it.type || 'string', htmlType: TYPE_TO_HTML[it.type || 'string'] || 'text', is_required: it.is_required !== false };
      if (it.type === 'options' || it.type === 'radio') {
        base.options = Array.isArray(it.options) ? it.options.filter(Boolean) : [];
        base.default_option = (it.default_option && String(it.default_option).trim()) || null;
      }
      return base;
    }
  });
}
function updatePreview() {
  var iframe = document.getElementById('previewIframe');
  if (!iframe || !iframe.contentWindow || !window._previewReady) return;
  var schema = buildFieldSchemaForPreview();
  iframe.contentWindow.postMessage({ fields: schema }, '*');
}
function renderField(f, grpId) {
  var isOpt = f.type === 'options' || f.type === 'radio';
  var optsList = [];
  if (isOpt) {
    var opts = Array.isArray(f.options) ? f.options : [];
    opts.forEach(function(opt, idx) {
      var val = (typeof opt === 'string' ? opt : (opt.value || '')).replace(/"/g, '&quot;');
      optsList.push('<div class="opts-row"><input class="finput opts-item" type="text" placeholder="e.g. A4, Small, Blue" value="' + val + '" oninput="updatePreview()"><button type="button" class="opts-remove" onclick="removeOption(' + f.id + ',' + idx + ',' + (grpId ? "'" + String(grpId).replace(/'/g, "\\'") + "'" : 'null') + ')">✕</button></div>');
    });
  }
  var typeOpts = TYPES.map(function(t) { return '<option value="' + t.value + '"' + ((f.type || 'string') === t.value ? ' selected' : '') + '>' + t.label + '</option>'; }).join('');
  var optsExtra = isOpt ? '<div class="field-options-extra">' +
    '<label class="flabel">Choices</label>' +
    '<div class="opts-list" id="opts-list-' + f.id + '">' + optsList.join('') + '</div>' +
    '<button type="button" class="btn btn-ghost btn-sm opts-add" onclick="addOption(' + f.id + ',' + (grpId ? "'" + String(grpId).replace(/'/g, "\\'") + "'" : 'null') + ')">+ Add choice</button>' +
    '<div class="fg" style="margin-top:12px;"><label class="flabel">Pre-selected (optional)</label><select class="fselect opts-default" data-id="' + f.id + '" onchange="updatePreview()"><option value="">None</option>' +
    (opts.filter(function(o) { var v = typeof o === 'string' ? o : (o.value || ''); return v; }).map(function(o) { var v = typeof o === 'string' ? o : (o.value || ''); return '<option value="' + v.replace(/"/g, '&quot;') + '"' + (f.default_option === v ? ' selected' : '') + '>' + v.replace(/</g, '&lt;') + '</option>'; }).join('')) +
    '</select></div></div>' : '';
  var grpIdJs = grpId ? '\'' + String(grpId).replace(/'/g, "\\'") + '\'' : null;
  var onchange = grpId ? 'updateField(' + f.id + ',\'type\',this.value,' + grpIdJs + '); renderFields();' : 'updateField(' + f.id + ',\'type\',this.value); renderFields();';
  return '<div class="form-builder-field-row' + (isOpt ? ' form-builder-field-options' : '') + '" id="field-' + f.id + '">' +
    '<div class="field-main">' +
    '<div class="fg"><label class="flabel">Field name</label><input class="finput" type="text" placeholder="e.g. client_name" value="' + (f.name || '').replace(/"/g, '&quot;') + '" oninput="updateField(' + f.id + ',\'name\',this.value' + (grpId ? ',' + grpIdJs : '') + ')"></div>' +
    '<div class="fg"><label class="flabel">Required</label><div class="radio-group">' +
    '<div class="radio-opt"><input type="radio" name="req_' + f.id + '" value="true" onchange="updateField(' + f.id + ',\'is_required\',true' + (grpId ? ',' + grpIdJs : '') + ')" ' + (f.is_required !== false ? 'checked' : '') + '><label>Yes</label></div>' +
    '<div class="radio-opt"><input type="radio" name="req_' + f.id + '" value="false" onchange="updateField(' + f.id + ',\'is_required\',false' + (grpId ? ',' + grpIdJs : '') + ')" ' + (f.is_required === false ? 'checked' : '') + '><label>No</label></div></div></div>' +
    '<div class="fg"><label class="flabel">Field type</label><select class="fselect" onchange="' + onchange + '">' + typeOpts + '</select></div>' +
    '<button type="button" class="del-btn" onclick="removeField(' + f.id + ',' + (grpId ? grpIdJs : 'null') + ')" title="Remove">✕</button>' +
    '</div>' + optsExtra + '</div>';
}
function renderFields() {
  var list = document.getElementById('fieldsList');
  var empty = document.getElementById('emptyState');
  var count = document.getElementById('fieldCount');
  count.textContent = totalCount();
  if (fields.length === 0) {
    list.innerHTML = '';
    empty.classList.add('show');
    return;
  }
  empty.classList.remove('show');
  var html = '';
  fields.forEach(function(it, idx) {
    if (isGroup(it)) {
      it.order = idx;
      var groupFields = (it.fields || []).map(function(f) { return renderField(f, it.id); }).join('');
      html += '<div class="form-builder-group" id="group-' + it.id + '">' +
        '<div class="form-builder-group-header">' +
        '<input type="text" class="form-input" placeholder="Group name (e.g. Customer Information)" value="' + (it.name || '').replace(/"/g, '&quot;') + '" oninput="updateGroup(\'' + it.id.replace(/'/g, "\\'") + '\',\'name\',this.value)">' +
        '<button type="button" class="btn btn-ghost btn-sm" onclick="removeGroup(\'' + it.id.replace(/'/g, "\\'") + '\')" title="Remove group">✕</button>' +
        '</div>' +
        '<div class="form-builder-group-fields">' + groupFields +
        '<button type="button" class="btn btn-ghost btn-sm form-builder-group-add" onclick="addField(\'' + it.id.replace(/'/g, "\\'") + '\')">+ Add field to group</button>' +
        '</div></div>';
    } else {
      html += renderField(it, null);
    }
  });
  list.innerHTML = html;
  fields.forEach(function(it) {
    if (isGroup(it)) {
      (it.fields || []).forEach(function(f) {
        var nameEl = document.querySelector('#field-' + f.id + ' .finput:not(.opts-item)');
        var typeEl = document.querySelector('#field-' + f.id + ' .fselect:not(.opts-default)');
        if (nameEl) nameEl.value = f.name || '';
        if (typeEl) typeEl.value = f.type || 'string';
        var r = document.querySelector('#field-' + f.id + ' input[name="req_' + f.id + '"][value="false"]');
        if (f.is_required === false && r) r.checked = true;
      });
    } else {
      var nameEl = document.querySelector('#field-' + it.id + ' .finput:not(.opts-item)');
      var typeEl = document.querySelector('#field-' + it.id + ' .fselect:not(.opts-default)');
      if (nameEl) nameEl.value = it.name || '';
      if (typeEl) typeEl.value = it.type || 'string';
      var r = document.querySelector('#field-' + it.id + ' input[name="req_' + it.id + '"][value="false"]');
      if (it.is_required === false && r) r.checked = true;
    }
  });
  updatePreview();
}
function collectOptionsFromField(fid, grpId) {
  var items = document.querySelectorAll('#field-' + fid + ' .opts-item');
  var arr = [];
  items.forEach(function(inp) { arr.push(inp.value.trim()); });
  return arr;
}
function addOption(fid, grpId) {
  var f;
  if (grpId) {
    var g = fields.find(function(x) { return x.id === grpId; });
    f = g && g.fields ? g.fields.find(function(x) { return x.id === fid; }) : null;
  } else {
    f = fields.find(function(x) { return isField(x) && x.id === fid; });
  }
  if (!f) return;
  f.options = collectOptionsFromField(fid, grpId);
  f.options.push('');
  renderFields();
}
function removeOption(fid, idx, grpId) {
  var f;
  if (grpId) {
    var g = fields.find(function(x) { return x.id === grpId; });
    f = g && g.fields ? g.fields.find(function(x) { return x.id === fid; }) : null;
  } else {
    f = fields.find(function(x) { return isField(x) && x.id === fid; });
  }
  if (!f) return;
  f.options = collectOptionsFromField(fid, grpId);
  f.options.splice(idx, 1);
  renderFields();
}
function showAlert(msg) {
  var box = document.getElementById('alertBox');
  box.textContent = '⚠️ ' + msg;
  box.style.display = 'block';
  setTimeout(function() { box.style.display = 'none'; }, 3500);
}
function collectFromDom() {
  fields.forEach(function(it) {
    if (isGroup(it)) {
      var groupEl = document.querySelector('#group-' + it.id + ' .form-builder-group-header input');
      if (groupEl) it.name = groupEl.value.trim();
      (it.fields || []).forEach(function(f) {
        var nameEl = document.querySelector('#field-' + f.id + ' .finput:not(.opts-item)');
        var typeEl = document.querySelector('#field-' + f.id + ' .fselect:not(.opts-default)');
        var reqEl = document.querySelector('#field-' + f.id + ' input[name="req_' + f.id + '"]:checked');
        if (nameEl) f.name = nameEl.value.trim();
        if (typeEl) f.type = typeEl.value;
        if (reqEl) f.is_required = reqEl.value === 'true';
        if (f.type === 'options' || f.type === 'radio') {
          var items = document.querySelectorAll('#field-' + f.id + ' .opts-item');
          if (items.length > 0) {
            f.options = [];
            items.forEach(function(inp) { f.options.push(inp.value.trim()); });
          }
          var defEl = document.querySelector('#field-' + f.id + ' .opts-default');
          f.default_option = (defEl && defEl.value) ? defEl.value : null;
        }
      });
    } else {
      var nameEl = document.querySelector('#field-' + it.id + ' .finput:not(.opts-item)');
      var typeEl = document.querySelector('#field-' + it.id + ' .fselect:not(.opts-default)');
      var reqEl = document.querySelector('#field-' + it.id + ' input[name="req_' + it.id + '"]:checked');
      if (nameEl) it.name = nameEl.value.trim();
      if (typeEl) it.type = typeEl.value;
      if (reqEl) it.is_required = reqEl.value === 'true';
      if (it.type === 'options' || it.type === 'radio') {
        var items = document.querySelectorAll('#field-' + it.id + ' .opts-item');
        if (items.length > 0) {
          it.options = [];
          items.forEach(function(inp) { it.options.push(inp.value.trim()); });
        }
        var defEl = document.querySelector('#field-' + it.id + ' .opts-default');
        it.default_option = (defEl && defEl.value) ? defEl.value : null;
      }
    }
  });
}
function buildPayload() {
  collectFromDom();
  return fields.map(function(it) {
    if (isGroup(it)) {
      return {
        id: it.id,
        name: it.name,
        order: it.order,
        fields: (it.fields || []).map(function(f) {
          var base = { id: f.id, name: f.name, type: f.type || 'string', is_required: f.is_required !== false };
          if (f.type === 'options' || f.type === 'radio') {
            base.options = Array.isArray(f.options) ? f.options.filter(Boolean) : [];
            base.default_option = (f.default_option && String(f.default_option).trim()) || null;
          }
          return base;
        })
      };
    } else {
      var base = { id: it.id, name: it.name, type: it.type || 'string', is_required: it.is_required !== false };
      if (it.type === 'options' || it.type === 'radio') {
        base.options = Array.isArray(it.options) ? it.options.filter(Boolean) : [];
        base.default_option = (it.default_option && String(it.default_option).trim()) || null;
      }
      return base;
    }
  });
}
function submitTemplate() {
  var payload = buildPayload();
  if (payload.length === 0) { showAlert('Add at least one field or group before saving.'); return; }
  var allFields = [];
  payload.forEach(function(it) {
    if (isGroup(it)) (it.fields || []).forEach(function(f) { allFields.push(f); });
    else allFields.push(it);
  });
  if (allFields.some(function(f) { return !f.name; })) { showAlert('All fields must have a name.'); return; }
  if (allFields.some(function(f) { return (f.type === 'options' || f.type === 'radio') && (!f.options || f.options.length === 0); })) {
    showAlert('Choose from list / Single choice fields need at least one choice.'); return;
  }
  if (allFields.some(function(f) {
    if ((f.type !== 'options' && f.type !== 'radio') || !f.default_option) return false;
    return f.options.indexOf(f.default_option) === -1;
  })) { showAlert('Pre-selected must be one of the choices above.'); return; }
  var names = allFields.map(function(f) { return f.name; });
  if (names.some(function(n, i) { return names.indexOf(n) !== i; })) { showAlert('Field names must be unique.'); return; }
  if (payload.some(function(it) { return isGroup(it) && !(it.name && it.name.trim()); })) {
    showAlert('All groups must have a name.'); return;
  }
  var templateName = document.getElementById('templateName').value.trim();
  fetch('/form/' + formId, {
    method: 'PATCH',
    headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
    body: JSON.stringify({ template_name: templateName || null, fields: payload })
  })
  .then(function(res) {
    if (!res.ok) return res.json().then(function(e) { throw new Error(e.message || 'Server error'); }).catch(function() { throw new Error('Server error ' + res.status); });
    return res.json();
  })
  .then(function() {
    window.location.href = '/form/' + formId + '/edit?success=' + encodeURIComponent('Form template updated successfully');
  })
  .catch(function(err) {
    showAlert(err.message || 'Failed to save');
  });
}
renderFields();
</script>
