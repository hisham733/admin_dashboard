<%
/* ── EJS helper functions ── */
function getOrderId(order) {
  if (order.fields && order.fields.order_id) {
    var v = order.fields.order_id.data;
    if (v != null && v !== '') return String(v);
  }
  return String(order.id);
}
function getCellValue(order, key) {
  if (!order.fields) return '—';
  var field = order.fields[key];
  if (!field) return '—';
  if (Array.isArray(field.data)) return field.data.length ? field.data.join(', ') : '—';
  return (field.data != null && field.data !== '') ? String(field.data) : '—';
}
function humanLabel(key) {
  return key.replace(/_/g, ' ').replace(/\b\w/g, function(c){ return c.toUpperCase(); });
}
%>

<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>

<div class="section-header">
  <h1 class="page-title">Dashboard</h1>
  <p class="page-subtitle">Order management &amp; analytics</p>
</div>

<!-- ─── Stat Cards ─── -->
<div class="stat-cards" style="grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));">
  <div class="stat-card">
    <div class="stat-card-label">Total Orders</div>
    <div class="stat-card-value"><%= stats.totalOrders %></div>
    <div class="stat-card-sub">All records</div>
  </div>
  <div class="stat-card">
    <div class="stat-card-label">Orders This Week</div>
    <div class="stat-card-value"><%= stats.ordersThisWeek %></div>
    <div class="stat-card-sub">Last 7 days</div>
  </div>
  <div class="stat-card">
    <div class="stat-card-label">Orders This Month</div>
    <div class="stat-card-value"><%= stats.ordersThisMonth %></div>
    <div class="stat-card-sub">Last 30 days</div>
  </div>
  <div class="stat-card">
    <div class="stat-card-label">Total Users</div>
    <div class="stat-card-value"><%= stats.totalUsers %></div>
    <div class="stat-card-sub">System users</div>
  </div>
</div>

<!-- ─── Orders Over Time Chart ─── -->
<div class="card" style="margin-bottom: 24px;">
  <div class="card-header">
    <div>
      <div class="card-title">Orders Over Time</div>
      <div class="card-sub">Order volume trend</div>
    </div>
    <div style="display:flex; gap:6px;">
      <button id="btnWeek"  class="btn btn-sm"            onclick="setChartPeriod('week')">Last Week</button>
      <button id="btnMonth" class="btn btn-sm btn-ghost"  onclick="setChartPeriod('month')">Last Month</button>
      <button id="btnYear"  class="btn btn-sm btn-ghost"  onclick="setChartPeriod('year')">Last Year</button>
    </div>
  </div>
  <div class="card-body">
    <canvas id="cOrders" height="110"></canvas>
  </div>
</div>

<!-- ─── Orders Table ─── -->
<div class="card">
  <div class="card-header" style="flex-wrap:wrap; gap:12px;">
    <div>
      <div class="card-title">All Orders</div>
      <div class="card-sub">
        Sorted newest first
        <% if (search) { %>&bull; filtered by &ldquo;<%= search %>&rdquo;<% } %>
      </div>
    </div>
    <div style="display:flex; gap:10px; align-items:center; flex-wrap:wrap;">

      <!-- Search form -->
      <form method="GET" action="/dashboard" id="srchForm" style="display:contents;">
        <input type="hidden" name="page"    value="1">
        <input type="hidden" name="perPage" value="<%= pagination.perPage %>">
        <div class="search-input" style="min-width:220px;">
          <span class="search-input-icon">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
          </span>
          <input type="text" name="search" value="<%= search %>" placeholder="Search all fields…"
                 onkeydown="if(event.key==='Enter'){document.getElementById('srchForm').submit();}">
        </div>
        <button type="submit" class="btn btn-ghost" style="white-space:nowrap;">Search</button>
        <% if (search) { %>
          <a href="/dashboard?perPage=<%= pagination.perPage %>" class="btn btn-ghost" style="white-space:nowrap;">Clear</a>
        <% } %>
      </form>

      <!-- Column visibility toggle -->
      <% if (allKeys.length > 0) { %>
      <div style="position:relative;">
        <button class="btn btn-ghost" id="colsBtn" onclick="toggleColPanel(event)">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right:4px;"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
          Columns
        </button>
        <div id="colPanel" style="display:none; position:absolute; right:0; top:calc(100% + 6px); z-index:200; min-width:200px; max-height:340px; overflow-y:auto; background:var(--surface-primary); border:1px solid var(--border-default); border-radius:var(--radius-md); box-shadow:var(--shadow-md); padding:8px 0;">
          <div style="padding:8px 14px 6px; font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:.06em; color:var(--text-muted); border-bottom:1px solid var(--border-default); margin-bottom:4px;">Show / hide columns</div>
          <% allKeys.forEach(function(key) { %>
            <label style="display:flex;align-items:center;gap:10px;padding:7px 14px;cursor:pointer;font-size:13px;"
                   onmouseover="this.style.background='var(--surface-secondary)'" onmouseout="this.style.background=''">
              <input type="checkbox" data-colkey="<%= key %>" onchange="toggleCol('<%= key %>',this.checked)"
                     style="width:15px;height:15px;cursor:pointer;">
              <span><%= humanLabel(key) %></span>
            </label>
          <% }); %>
        </div>
      </div>
      <% } %>

    </div>
  </div><!-- /card-header -->

  <div class="table-wrap">
    <table class="table">
      <thead>
        <tr>
          <th>Order ID</th>
          <th>PDF</th>
          <% allKeys.forEach(function(key) { %>
            <th class="dyn-col" data-col="<%= key %>" style="display:none;"><%= humanLabel(key) %></th>
          <% }); %>
        </tr>
      </thead>
      <tbody>
        <% if (!orders || orders.length === 0) { %>
          <tr>
            <td colspan="<%= 2 + allKeys.length %>">
              <div class="empty-state">
                <div class="empty-state-icon">
                  <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2"/><rect x="9" y="3" width="6" height="4" rx="1"/></svg>
                </div>
                <div class="empty-state-title"><%= search ? 'No orders match your search' : 'No orders yet' %></div>
              </div>
            </td>
          </tr>
        <% } else { %>
          <% orders.forEach(function(order) { %>
            <tr>
              <td><span class="badge badge-primary"><%= getOrderId(order) %></span></td>
              <td>
                <% if (order.pdf_url) { %>
                  <a href="<%= order.pdf_url %>" target="_blank" rel="noopener" class="btn btn-sm btn-ghost" style="font-size:12px;">View PDF</a>
                <% } else { %>
                  <span style="color:var(--text-muted);">—</span>
                <% } %>
              </td>
              <% allKeys.forEach(function(key) { %>
                <td class="dyn-col" data-col="<%= key %>" style="display:none; font-size:13px;"><%= getCellValue(order, key) %></td>
              <% }); %>
            </tr>
          <% }); %>
        <% } %>
      </tbody>
    </table>
  </div><!-- /table-wrap -->

  <!-- Pagination row -->
  <div style="display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:10px; padding:12px 20px; border-top:1px solid var(--border-default);">
    <!-- Per-page selector -->
    <div style="display:flex; align-items:center; gap:10px;">
      <span class="pagination-info">
        <% var _start = (pagination.page - 1) * pagination.perPage + 1; %>
        <% var _end   = Math.min(pagination.total, pagination.page * pagination.perPage); %>
        <% if (pagination.total > 0) { %>
          Showing <%= _start %>–<%= _end %> of <%= pagination.total %>
        <% } else { %>
          No results
        <% } %>
      </span>
      <select class="form-input" style="width:auto; padding:4px 10px; font-size:13px;" onchange="setPerPage(this.value)">
        <% [5, 10, 25, 50].forEach(function(n) { %>
          <option value="<%= n %>" <%- n === pagination.perPage ? 'selected' : '' %>><%= n %> / page</option>
        <% }); %>
      </select>
    </div>
    <!-- Page buttons -->
    <div class="pagination-controls" id="pagBtns">
      <%
        var _tp  = Math.max(1, Math.ceil(pagination.total / pagination.perPage));
        var _cp  = pagination.page;
        var _qs  = function(overrides) {
          var p = Object.assign({}, query, overrides);
          return Object.keys(p)
            .filter(function(k){ return p[k] !== null && p[k] !== undefined && p[k] !== ''; })
            .map(function(k){ return encodeURIComponent(k) + '=' + encodeURIComponent(p[k]); })
            .join('&');
        };
      %>
      <% if (_tp > 1) { %>
        <% if (_cp > 1) { %>
          <a href="/dashboard?<%= _qs({page: _cp - 1}) %>" class="pagination-btn">‹</a>
        <% } else { %>
          <button class="pagination-btn" disabled>‹</button>
        <% } %>

        <%
          var _pages = [];
          if (_tp <= 7) {
            for (var _pi = 1; _pi <= _tp; _pi++) _pages.push(_pi);
          } else {
            _pages.push(1);
            if (_cp > 3) _pages.push('…');
            var _lo = Math.max(2, _cp - 1);
            var _hi = Math.min(_tp - 1, _cp + 1);
            for (var _pj = _lo; _pj <= _hi; _pj++) _pages.push(_pj);
            if (_cp < _tp - 2) _pages.push('…');
            _pages.push(_tp);
          }
        %>
        <% _pages.forEach(function(p) { %>
          <% if (p === '…') { %>
            <span class="pagination-btn" style="cursor:default;pointer-events:none;">…</span>
          <% } else { %>
            <a href="/dashboard?<%= _qs({page: p}) %>" class="pagination-btn <%= p === _cp ? 'active' : '' %>"><%= p %></a>
          <% } %>
        <% }); %>

        <% if (_cp < _tp) { %>
          <a href="/dashboard?<%= _qs({page: _cp + 1}) %>" class="pagination-btn">›</a>
        <% } else { %>
          <button class="pagination-btn" disabled>›</button>
        <% } %>
      <% } %>
    </div>
  </div>

</div><!-- /card -->

<script>
(function () {
  /* ── chart (data pre-computed server-side) ── */
  var CHART_DATA    = <%- JSON.stringify(chartData) %>;
  var ordersChart   = null;
  var currentPeriod = 'week';

  window.setChartPeriod = function (period) {
    currentPeriod = period;
    ['week', 'month', 'year'].forEach(function (p) {
      var id  = 'btn' + p.charAt(0).toUpperCase() + p.slice(1);
      var btn = document.getElementById(id);
      if (btn) btn.className = (p === period) ? 'btn btn-sm' : 'btn btn-sm btn-ghost';
    });
    renderChart();
  };

  function renderChart() {
    var cd = CHART_DATA[currentPeriod];
    if (ordersChart) ordersChart.destroy();
    ordersChart = new Chart(document.getElementById('cOrders'), {
      type: 'line',
      data: {
        labels: cd.labels,
        datasets: [{
          label: 'Orders',
          data: cd.data,
          borderColor: '#2563eb',
          backgroundColor: 'rgba(37,99,235,0.08)',
          fill: true,
          tension: 0.35,
          borderWidth: 2,
          pointRadius: 3,
          pointHoverRadius: 5
        }]
      },
      options: {
        responsive: true,
        plugins: { legend: { display: false } },
        scales: { y: { beginAtZero: true, ticks: { precision: 0 } } }
      }
    });
  }

  /* ── column visibility (client-side only — no server round-trip) ── */
  window.toggleCol = function (key, visible) {
    document.querySelectorAll('[data-col="' + key + '"]').forEach(function (el) {
      el.style.display = visible ? '' : 'none';
    });
  };

  window.toggleColPanel = function (e) {
    e.stopPropagation();
    var panel = document.getElementById('colPanel');
    if (panel) panel.style.display = panel.style.display === 'none' ? 'block' : 'none';
  };

  document.addEventListener('click', function (e) {
    var panel = document.getElementById('colPanel');
    var btn   = document.getElementById('colsBtn');
    if (panel && btn && !btn.contains(e.target) && !panel.contains(e.target)) {
      panel.style.display = 'none';
    }
  });

  /* ── per-page selector ── */
  window.setPerPage = function (val) {
    var url = new URL(window.location.href);
    url.searchParams.set('perPage', val);
    url.searchParams.set('page', '1');
    window.location.href = url.toString();
  };

  /* ── init ── */
  renderChart();
}());
</script>
