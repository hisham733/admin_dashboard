<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>

<div class="section-header">
  <h1 class="page-title">Business Overview</h1>
  <p class="page-subtitle">Real-time order management & analytics</p>
    </div>

<div class="stat-cards">
  <div class="stat-card">
    <div class="stat-card-label">Total Orders</div>
    <div class="stat-card-value" id="wTotal">0</div>
    <div class="stat-card-sub">All records</div>
  </div>
  <div class="stat-card">
    <div class="stat-card-label">Services</div>
    <div class="stat-card-value" id="wSvc">0</div>
    <div class="stat-card-sub">Unique types</div>
  </div>
  <div class="stat-card">
    <div class="stat-card-label">Urgent</div>
    <div class="stat-card-value" id="wUrgent">0</div>
    <div class="stat-card-sub">Flagged in notes</div>
  </div>
  <div class="stat-card">
    <div class="stat-card-label">Pickup</div>
    <div class="stat-card-value" id="wPickup">0</div>
    <div class="stat-card-sub">Delivery method</div>
  </div>
  <div class="stat-card">
    <div class="stat-card-label">Customers</div>
    <div class="stat-card-value" id="wCustomers">0</div>
    <div class="stat-card-sub">Unique identities</div>
  </div>
  </div>

<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 16px; margin-bottom: 24px;">
  <div class="card">
    <div class="card-header">
      <div>
        <div class="card-title">Orders by Service</div>
        <div class="card-sub">Volume per service type</div>
      </div>
    </div>
    <div class="card-body">
      <canvas id="cService" height="200"></canvas>
    </div>
  </div>
  <div class="card">
    <div class="card-header">
      <div>
        <div class="card-title">Delivery Method</div>
        <div class="card-sub">Split breakdown</div>
      </div>
    </div>
    <div class="card-body">
      <canvas id="cDelivery" height="200"></canvas>
    </div>
  </div>
</div>

<div class="card">
  <div class="card-header">
    <div>
      <div class="card-title">All Orders</div>
      <div class="card-sub">Order list</div>
    </div>
    <div class="search-input" style="min-width: 200px;">
      <span class="search-input-icon">🔍</span>
      <input type="text" id="srchInput" placeholder="Search order, client, product..." oninput="filterTable()">
    </div>
  </div>
  <div class="table-wrap">
    <table class="table">
      <thead>
        <tr>
          <th>Order #</th>
          <th>Client</th>
          <th>Service</th>
          <th>Product</th>
          <th>Deadline</th>
        </tr>
      </thead>
      <tbody id="tBody"></tbody>
    </table>
  </div>
  <div class="pagination">
    <span class="pagination-info" id="tCount">0 orders</span>
    </div>
  </div>

<script>
var ORDERS = <%- JSON.stringify(typeof orders !== 'undefined' ? orders : []) %>;

function esc(s){return String(s==null?'':s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');}
function freq(arr){return arr.reduce(function(a,v){a[v]=(a[v]||0)+1;return a;},{});}
function sortF(arr){return Object.entries(freq(arr)).sort(function(a,b){return b[1]-a[1];});}

var PAL=['#2563eb','#7c3aed','#059669','#dc2626','#ea580c','#ca8a04'];

var custMap={};
ORDERS.forEach(function(o){
  var k=(o.client_name||'Unknown').trim()+'||'+(o.phone||'').trim();
  if(!custMap[k]){custMap[k]={name:(o.client_name||'Unknown').trim(),phone:(o.phone||'—').trim(),orders:[],services:{}};}
  custMap[k].orders.push(o);
  if(o.service)custMap[k].services[o.service]=true;
});
var CUSTOMERS=Object.values(custMap).sort(function(a,b){return b.orders.length-a.orders.length;});

document.getElementById('wTotal').textContent=ORDERS.length;
document.getElementById('wSvc').textContent=new Set(ORDERS.map(function(o){return o.service;}).filter(Boolean)).size;
document.getElementById('wUrgent').textContent=ORDERS.filter(function(o){return o.notes&&o.notes.toLowerCase().indexOf('urgent')!==-1;}).length;
document.getElementById('wPickup').textContent=ORDERS.filter(function(o){return(o.delivery||'').toLowerCase()==='pickup';}).length;
document.getElementById('wCustomers').textContent=CUSTOMERS.length;

function renderOrdersTable(data){
  document.getElementById('tCount').textContent=data.length + ' orders';
  if(!data.length){document.getElementById('tBody').innerHTML='<tr><td colspan="5"><div class="empty-state"><div class="empty-state-icon">📭</div><div class="empty-state-title">No orders yet</div></div></td></tr>';return;}
  document.getElementById('tBody').innerHTML=data.map(function(o){
    return '<tr data-s="'+esc([o.order_no,o.client_name,o.phone,o.service,o.product].join(' ')).toLowerCase()+'">'+
      '<td><span class="badge badge-primary">'+esc(o.order_no)+'</span></td>'+
      '<td><div class="user-name">'+esc(o.client_name)+'</div><div class="user-email">'+esc(o.phone)+'</div></td>'+
      '<td><span class="badge badge-muted">'+esc(o.service||'—')+'</span></td>'+
      '<td>'+esc(o.product||'—')+'</td>'+
      '<td style="color: var(--text-muted);">'+esc(o.deadline||'—')+'</td>'+
    '</tr>';
  }).join('');
}
renderOrdersTable(ORDERS);

function filterTable(){
  var q=document.getElementById('srchInput').value.toLowerCase();
  var rows=document.querySelectorAll('#tBody tr[data-s]');
  var vis=0;
  rows.forEach(function(r){var s=!q||(r.dataset.s||'').indexOf(q)!==-1;r.style.display=s?'':'none';if(s)vis++;});
  document.getElementById('tCount').textContent=vis+' of '+ORDERS.length+' orders';
}

if(ORDERS.length){
  var sf=sortF(ORDERS.map(function(o){return o.service||'Unknown';}));
  new Chart(document.getElementById('cService'),{
    type:'bar',
    data:{labels:sf.map(function(e){return e[0];}),datasets:[{data:sf.map(function(e){return e[1];}),backgroundColor:PAL,borderRadius:8,borderSkipped:false}]},
    options:{responsive:true,plugins:{legend:{display:false}},scales:{y:{beginAtZero:true}}}
  });
  var df=sortF(ORDERS.map(function(o){return o.delivery||'Unknown';}));
  new Chart(document.getElementById('cDelivery'),{
    type:'doughnut',
    data:{labels:df.map(function(e){return e[0];}),datasets:[{data:df.map(function(e){return e[1];}),backgroundColor:PAL,borderColor:'var(--surface-primary)',borderWidth:4}]},
    options:{responsive:true,cutout:'60%',plugins:{legend:{position:'bottom'}}}
  });
}
</script>
