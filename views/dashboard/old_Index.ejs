<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Orders Dashboard</title>
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
    <style>
        :root {
            --ink:   #0d0d14;
            --card:  #13131c;
            --card2: #1a1a26;
            --line:  #22223a;
            --gold:  #f5c842;
            --sky:   #4fc3f7;
            --coral: #ff6f61;
            --mint:  #56e39f;
            --lilac: #c084fc;
            --orange:#f97316;
            --text:  #e2e2f0;
            --muted: #6b6b8f;
            --r:     14px;
        }
        *{margin:0;padding:0;box-sizing:border-box;}
        body{font-family:'Outfit',sans-serif;background:var(--ink);color:var(--text);min-height:100vh;}
        body::before{content:'';position:fixed;inset:0;background-image:linear-gradient(rgba(255,255,255,.015) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.015) 1px,transparent 1px);background-size:44px 44px;pointer-events:none;}

        /* ── Header ── */
        .hdr{padding:24px 36px;border-bottom:1px solid var(--line);background:var(--card);display:flex;align-items:flex-end;justify-content:space-between;gap:16px;}
        .hdr h1{font-family:'Bebas Neue',sans-serif;font-size:clamp(28px,4vw,48px);letter-spacing:2px;color:#fff;line-height:1;}
        .hdr h1 em{color:var(--gold);font-style:normal;}
        .hdr p{font-size:12px;color:var(--muted);margin-top:4px;}
        .live-pill{display:inline-flex;align-items:center;gap:6px;padding:4px 12px;border-radius:20px;font-size:11px;background:rgba(86,227,159,.1);border:1px solid rgba(86,227,159,.25);color:var(--mint);white-space:nowrap;}
        .live-dot{width:6px;height:6px;border-radius:50%;background:var(--mint);box-shadow:0 0 5px var(--mint);animation:pulse 1.6s infinite;}
        @keyframes pulse{0%,100%{opacity:1;}50%{opacity:.3;}}

        /* ── Layout ── */
        .wrap{padding:28px 36px;}
        .section-label{font-family:'Bebas Neue',sans-serif;font-size:13px;letter-spacing:3px;color:var(--muted);text-transform:uppercase;margin-bottom:14px;display:flex;align-items:center;gap:10px;}
        .section-label::after{content:'';flex:1;height:1px;background:var(--line);}

        /* ── Widgets ── */
        .widgets{display:grid;grid-template-columns:repeat(5,1fr);gap:14px;margin-bottom:26px;}
        .w{background:var(--card);border:1px solid var(--line);border-radius:var(--r);padding:18px 20px;position:relative;overflow:hidden;animation:fadeUp .4s both;}
        .w::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;}
        .w:nth-child(1)::before{background:var(--gold);}
        .w:nth-child(2)::before{background:var(--sky);}
        .w:nth-child(3)::before{background:var(--coral);}
        .w:nth-child(4)::before{background:var(--mint);}
        .w:nth-child(5)::before{background:var(--lilac);}
        .w:nth-child(1){animation-delay:.05s;}.w:nth-child(2){animation-delay:.1s;}.w:nth-child(3){animation-delay:.15s;}.w:nth-child(4){animation-delay:.2s;}.w:nth-child(5){animation-delay:.25s;}
        .w-icon{font-size:18px;margin-bottom:8px;}
        .w-label{font-size:10px;text-transform:uppercase;letter-spacing:1.5px;color:var(--muted);margin-bottom:4px;}
        .w-val{font-family:'Bebas Neue',sans-serif;font-size:38px;letter-spacing:1px;line-height:1;}
        .w:nth-child(1) .w-val{color:var(--gold);}
        .w:nth-child(2) .w-val{color:var(--sky);}
        .w:nth-child(3) .w-val{color:var(--coral);}
        .w:nth-child(4) .w-val{color:var(--mint);}
        .w:nth-child(5) .w-val{color:var(--lilac);}
        .w-sub{font-size:11px;color:var(--muted);margin-top:2px;}

        /* ── Cards ── */
        .card{background:var(--card);border:1px solid var(--line);border-radius:var(--r);padding:22px 24px;animation:fadeUp .4s both;}
        .card-title{font-family:'Bebas Neue',sans-serif;font-size:17px;letter-spacing:1px;color:#fff;margin-bottom:2px;}
        .card-sub{font-size:11px;color:var(--muted);margin-bottom:16px;}

        /* ── Grid rows ── */
        .row3{display:grid;grid-template-columns:1.7fr 1fr 1fr;gap:14px;margin-bottom:26px;}
        .row3 .card:nth-child(1){animation-delay:.3s;}.row3 .card:nth-child(2){animation-delay:.35s;}.row3 .card:nth-child(3){animation-delay:.4s;}
        .row2{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:26px;}
        .row2 .card:nth-child(1){animation-delay:.45s;}.row2 .card:nth-child(2){animation-delay:.5s;}
        .row2b{display:grid;grid-template-columns:1.2fr 1fr;gap:14px;margin-bottom:26px;}
        .row2b .card:nth-child(1){animation-delay:.5s;}.row2b .card:nth-child(2){animation-delay:.55s;}

        /* ── Leaderboard ── */
        .lb-row{display:flex;align-items:center;gap:10px;padding:9px 0;border-bottom:1px solid var(--line);}
        .lb-row:last-child{border:none;}
        .lb-rank{font-family:'Bebas Neue',sans-serif;font-size:17px;width:20px;color:var(--muted);}
        .lb-rank.g{color:var(--gold);}
        .lb-av{width:28px;height:28px;border-radius:7px;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:11px;font-family:'Bebas Neue',sans-serif;flex-shrink:0;}
        .lb-name{flex:1;font-size:13px;font-weight:500;}
        .lb-detail{font-size:11px;color:var(--muted);}
        .lb-bar-wrap{width:70px;height:3px;background:var(--line);border-radius:2px;overflow:hidden;}
        .lb-bar{height:100%;border-radius:2px;}
        .lb-num{font-family:'Bebas Neue',sans-serif;font-size:17px;width:22px;text-align:right;}

        /* ── Tag cloud ── */
        .tag-cloud{display:flex;flex-wrap:wrap;gap:7px;margin-bottom:14px;}
        .ftag{padding:4px 11px;border-radius:20px;font-size:11px;font-weight:500;border:1px solid;}

        /* ── Export button ── */
        .export-btn{display:inline-flex;align-items:center;gap:6px;padding:6px 14px;border-radius:8px;font-size:12px;font-weight:600;background:rgba(245,200,66,.08);border:1px solid rgba(245,200,66,.2);color:var(--gold);cursor:pointer;transition:all .2s;font-family:'Outfit',sans-serif;}
        .export-btn:hover{background:rgba(245,200,66,.18);border-color:var(--gold);}
        .export-btn-mint{background:rgba(86,227,159,.08);border-color:rgba(86,227,159,.2);color:var(--mint);}
        .export-btn-mint:hover{background:rgba(86,227,159,.18);border-color:var(--mint);}

        /* ── Table toolbar ── */
        .tbl-card{background:var(--card);border:1px solid var(--line);border-radius:var(--r);overflow:hidden;animation:fadeUp .4s .55s both;}
        .tbl-toolbar{display:flex;align-items:center;justify-content:space-between;padding:14px 22px;border-bottom:1px solid var(--line);gap:12px;flex-wrap:wrap;}
        .tbl-left{display:flex;align-items:center;gap:10px;flex-wrap:wrap;}
        .tbl-title{font-family:'Bebas Neue',sans-serif;font-size:20px;letter-spacing:1px;}
        .tbl-count{font-size:12px;color:var(--muted);}
        .srch-box{display:flex;align-items:center;gap:8px;background:var(--card2);border:1px solid var(--line);border-radius:8px;padding:7px 13px;width:260px;}
        .srch-box input{background:none;border:none;outline:none;color:var(--text);font-family:'Outfit',sans-serif;font-size:13px;width:100%;}
        .srch-box input::placeholder{color:var(--muted);}

        /* ── Tables ── */
        .tbl-wrap{overflow-x:auto;}
        table{width:100%;border-collapse:collapse;}
        thead th{padding:10px 16px;text-align:left;font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:1.4px;color:var(--muted);background:var(--card2);border-bottom:1px solid var(--line);white-space:nowrap;}
        thead th.sort-col{cursor:pointer;}
        thead th.sort-col:hover{color:var(--text);}
        tbody tr{border-bottom:1px solid var(--line);transition:background .15s;}
        tbody tr:last-child{border:none;}
        tbody tr:hover{background:var(--card2);}
        tbody td{padding:11px 16px;font-size:13px;vertical-align:middle;}
        .ord-no{font-family:'Bebas Neue',sans-serif;font-size:16px;color:var(--gold);}
        .cn{font-weight:600;}
        .cp{font-size:11px;color:var(--muted);margin-top:1px;}
        .chip{display:inline-block;padding:3px 9px;border-radius:20px;font-size:11px;font-weight:500;background:var(--card2);border:1px solid var(--line);color:var(--muted);}
        .pdf-btn{display:inline-flex;align-items:center;gap:4px;padding:4px 10px;border-radius:7px;font-size:11px;font-weight:600;background:rgba(245,200,66,.1);border:1px solid rgba(245,200,66,.22);color:var(--gold);text-decoration:none;transition:all .2s;white-space:nowrap;}
        .pdf-btn:hover{background:rgba(245,200,66,.2);border-color:var(--gold);}
        .del-btn{display:inline-flex;align-items:center;gap:4px;padding:4px 10px;border-radius:7px;font-size:11px;font-weight:600;background:rgba(255,111,97,.08);border:1px solid rgba(255,111,97,.2);color:var(--coral);text-decoration:none;transition:all .2s;white-space:nowrap;}
        .del-btn:hover{background:rgba(255,111,97,.18);border-color:var(--coral);}
        .urgent-dot{display:inline-block;width:6px;height:6px;border-radius:50%;background:var(--coral);box-shadow:0 0 5px var(--coral);margin-right:4px;animation:pulse 1.4s infinite;}
        td.dim{color:var(--muted);font-size:12px;}

        /* ── Customer table specifics ── */
        .cust-orders{display:flex;flex-wrap:wrap;gap:4px;}
        .order-tag{padding:2px 7px;border-radius:5px;font-size:10px;font-weight:600;background:rgba(245,200,66,.1);border:1px solid rgba(245,200,66,.15);color:var(--gold);white-space:nowrap;}
        .rank-badge{display:inline-flex;align-items:center;justify-content:center;width:22px;height:22px;border-radius:6px;font-family:'Bebas Neue',sans-serif;font-size:13px;}
        .rank-1{background:rgba(245,200,66,.15);color:var(--gold);}
        .rank-2{background:rgba(79,195,247,.1);color:var(--sky);}
        .rank-3{background:rgba(180,127,255,.1);color:var(--lilac);}
        .rank-n{background:var(--card2);color:var(--muted);}

        /* ── FAB & Modal ── */
        .fab{position:fixed;bottom:28px;right:28px;width:50px;height:50px;border-radius:50%;background:var(--gold);border:none;cursor:pointer;font-size:24px;display:flex;align-items:center;justify-content:center;color:#0d0d14;box-shadow:0 4px 24px rgba(245,200,66,.35);transition:all .2s;z-index:100;}
        .fab:hover{transform:scale(1.08);box-shadow:0 6px 28px rgba(245,200,66,.5);}
        .overlay{position:fixed;inset:0;background:rgba(0,0,0,.65);backdrop-filter:blur(4px);z-index:200;display:none;align-items:center;justify-content:center;}
        .overlay.open{display:flex;}
        .modal{background:var(--card);border:1px solid var(--line);border-radius:18px;padding:30px;width:560px;max-width:95vw;max-height:90vh;overflow-y:auto;animation:modalIn .3s cubic-bezier(.34,1.56,.64,1);}
        @keyframes modalIn{from{opacity:0;transform:scale(.9) translateY(16px);}to{opacity:1;transform:scale(1) translateY(0);}}
        .modal-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:22px;}
        .modal-title{font-family:'Bebas Neue',sans-serif;font-size:24px;letter-spacing:1px;}
        .modal-close{width:30px;height:30px;border-radius:8px;border:1px solid var(--line);background:transparent;color:var(--muted);cursor:pointer;font-size:16px;display:flex;align-items:center;justify-content:center;transition:all .2s;}
        .modal-close:hover{color:var(--text);background:var(--card2);}
        .fgrid{display:grid;grid-template-columns:1fr 1fr;gap:14px;}
        .fg{display:flex;flex-direction:column;gap:5px;}
        .fg.full{grid-column:span 2;}
        .flabel{font-size:10px;text-transform:uppercase;letter-spacing:1.2px;color:var(--muted);}
        .finput{padding:9px 13px;background:var(--card2);border:1px solid var(--line);border-radius:8px;color:var(--text);font-family:'Outfit',sans-serif;font-size:13px;outline:none;transition:border-color .2s;}
        .finput:focus{border-color:var(--gold);}
        .finput::placeholder{color:var(--muted);}
        .form-actions{display:flex;justify-content:flex-end;gap:10px;margin-top:22px;}
        .btn-cancel{padding:9px 18px;border-radius:8px;border:1px solid var(--line);background:transparent;color:var(--muted);font-family:'Outfit',sans-serif;font-size:13px;cursor:pointer;transition:all .2s;}
        .btn-cancel:hover{color:var(--text);background:var(--card2);}
        .btn-submit{padding:9px 22px;border-radius:8px;border:none;background:var(--gold);color:#0d0d14;font-family:'Bebas Neue',sans-serif;font-size:16px;letter-spacing:.5px;cursor:pointer;transition:all .2s;}
        .btn-submit:hover{background:#d4b030;}

        @keyframes fadeUp{from{opacity:0;transform:translateY(14px);}to{opacity:1;transform:translateY(0);}}
        ::-webkit-scrollbar{width:4px;height:4px;}
        ::-webkit-scrollbar-track{background:var(--ink);}
        ::-webkit-scrollbar-thumb{background:var(--line);border-radius:2px;}

        @media(max-width:1200px){.widgets{grid-template-columns:repeat(3,1fr);}.row3{grid-template-columns:1fr 1fr;}.row3 .card:first-child{grid-column:span 2;}}
        @media(max-width:860px){.widgets{grid-template-columns:1fr 1fr;}.row3,.row2,.row2b{grid-template-columns:1fr;}.row3 .card:first-child{grid-column:span 1;}.wrap{padding:18px 16px;}.hdr{padding:20px 16px;}}
    </style>
</head>
<body>

<!-- ═══ HEADER ═══ -->
<header class="hdr">
    <div>
        <h1>Orders <em>Dashboard</em></h1>
        <p>Source: <strong>orders</strong> table</p>
    </div>
    <div class="live-pill">
        <span class="live-dot"></span>
        <%= orders.length %> records
    </div>
</header>

<main class="wrap">

    <!-- ═══ OVERVIEW WIDGETS ═══ -->
    <div class="section-label">Overview</div>
    <div class="widgets">
        <div class="w">
            <div class="w-icon">📦</div>
            <div class="w-label">Total Orders</div>
            <div class="w-val"><%= orders.length %></div>
            <div class="w-sub">All records</div>
        </div>
        <div class="w">
            <div class="w-icon">🖨️</div>
            <div class="w-label">Services</div>
            <div class="w-val" id="wSvc">—</div>
            <div class="w-sub">Unique types</div>
        </div>
        <div class="w">
            <div class="w-icon">🚨</div>
            <div class="w-label">Urgent</div>
            <div class="w-val" id="wUrgent">—</div>
            <div class="w-sub">Flagged in notes</div>
        </div>
        <div class="w">
            <div class="w-icon">📬</div>
            <div class="w-label">Pickup</div>
            <div class="w-val" id="wPickup">—</div>
            <div class="w-sub">Delivery method</div>
        </div>
        <div class="w">
            <div class="w-icon">👤</div>
            <div class="w-label">Unique Customers</div>
            <div class="w-val" id="wCustomers">—</div>
            <div class="w-sub">By name + phone</div>
        </div>
    </div>

    <!-- ═══ ORDER CHARTS ═══ -->
    <div class="section-label">Order Analytics</div>
    <div class="row3">
        <div class="card">
            <div class="card-title">Orders by Service</div>
            <div class="card-sub">Volume per service type</div>
            <canvas id="cService"></canvas>
        </div>
        <div class="card">
            <div class="card-title">Delivery Method</div>
            <div class="card-sub">Pickup vs courier split</div>
            <canvas id="cDelivery"></canvas>
        </div>
        <div class="card">
            <div class="card-title">Orders by Date</div>
            <div class="card-sub">Grouped by creation day</div>
            <canvas id="cTime"></canvas>
        </div>
    </div>

    <div class="row2">
        <div class="card">
            <div class="card-title">Sender Leaderboard</div>
            <div class="card-sub">Orders submitted per sender</div>
            <div id="lbList"></div>
        </div>
        <div class="card">
            <div class="card-title">Finishing Types</div>
            <div class="card-sub">Methods used across orders</div>
            <div class="tag-cloud" id="fTags"></div>
            <canvas id="cFinishing"></canvas>
        </div>
    </div>

    <!-- ═══ CUSTOMER SECTION ═══ -->
    <div class="section-label">Customer Analysis</div>
    <div class="row2b">
        <!-- Top 5 chart -->
        <div class="card">
            <div class="card-title">Top 5 Customers</div>
            <div class="card-sub">By number of orders placed</div>
            <canvas id="cTop5"></canvas>
        </div>
        <!-- Customer stats -->
        <div class="card">
            <div class="card-title">Customer Stats</div>
            <div class="card-sub">Breakdown at a glance</div>
            <div id="custStats"></div>
        </div>
    </div>

    <!-- Customer full table -->
    <div class="tbl-card" style="margin-bottom:26px;animation-delay:.6s">
        <div class="tbl-toolbar">
            <div class="tbl-left">
                <span class="tbl-title">Customer Report</span>
                <span class="tbl-count" id="custCount"></span>
            </div>
            <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;">
                <div class="srch-box">
                    <span style="color:var(--muted)">⌕</span>
                    <input type="text" id="custSearch" placeholder="Search customer…" oninput="filterCustomers()">
                </div>
                <button class="export-btn export-btn-mint" onclick="exportCustomerCSV()">
                    &#8595; Export Customer Report
                </button>
            </div>
        </div>
        <div class="tbl-wrap">
            <table id="custTable">
                <thead>
                    <tr>
                        <th>Rank</th>
                        <th>Customer</th>
                        <th>Phone</th>
                        <th>Total Orders</th>
                        <th>Services Used</th>
                        <th>Order Numbers</th>
                        <th>Latest Order</th>
                    </tr>
                </thead>
                <tbody id="custBody"></tbody>
            </table>
        </div>
    </div>

    <!-- ═══ ORDERS TABLE ═══ -->
    <div class="section-label">Orders</div>
    <div class="tbl-card">
        <div class="tbl-toolbar">
            <div class="tbl-left">
                <span class="tbl-title">All Orders</span>
                <span class="tbl-count" id="tCount">(<%= orders.length %>)</span>
            </div>
            <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;">
                <div class="srch-box">
                    <span style="color:var(--muted)">⌕</span>
                    <input type="text" id="srchInput" placeholder="Search order, client, product…" oninput="filterTable()">
                </div>
                <button class="export-btn" onclick="exportOrdersCSV()">
                    &#8595; Export Orders CSV
                </button>
            </div>
        </div>
        <div class="tbl-wrap">
            <table>
                <thead>
                    <tr>
                        <th>Order #</th>
                        <th>Client</th>
                        <th>Service</th>
                        <th>Product</th>
                        <th>Qty</th>
                        <th>Paper</th>
                        <th>Finishing</th>
                        <th>Deadline</th>
                        <th>Delivery</th>
                        <th>Sender</th>
                        <th>Notes</th>
                        <th>PDF</th>
                    </tr>
                </thead>
                <tbody id="tBody">
                    <% for (var i = 0; i < orders.length; i++) { %>
                    <%
                        var o = orders[i];
                        var searchStr = [o.order_no, o.client_name, o.phone, o.service, o.product, o.send, o.finishing, o.delivery, o.paper].join(' ');
                        var isUrgent = o.notes && o.notes.toLowerCase().indexOf('urgent') !== -1;
                        var safeNotes = o.notes ? o.notes.substring(0, 55) : '';
                    %>
                    <tr data-s="<%= searchStr.toLowerCase() %>">
                        <td><span class="ord-no"><%= o.order_no %></span></td>
                        <td>
                            <div class="cn">
                                <% if (isUrgent) { %><span class="urgent-dot"></span><% } %>
                                <%= o.client_name %>
                            </div>
                            <div class="cp"><%= o.phone || '' %></div>
                        </td>
                        <td><span class="chip"><%= o.service || '—' %></span></td>
                        <td style="max-width:150px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis"><%= o.product || '—' %></td>
                        <td style="text-align:center"><%= o.quantity || '—' %></td>
                        <td class="dim"><%= o.paper || '—' %></td>
                        <td><span class="chip"><%= o.finishing || '—' %></span></td>
                        <td style="white-space:nowrap"><%= o.deadline || '—' %></td>
                        <td><%= o.delivery || '—' %></td>
                        <td>
                            <span style="display:inline-flex;align-items:center;gap:6px;">
                                <span class="sender-av" data-name="<%= o.send || '' %>"></span>
                                <%= o.send || '—' %>
                            </span>
                        </td>
                        <td class="dim" style="max-width:150px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">
                            <%= safeNotes %><% if (o.notes && o.notes.length > 55) { %>…<% } %>
                        </td>
                        <td>
                            <% if (o.pdf_link) { %>
                                <a href="<%= o.pdf_link %>" target="_blank" class="pdf-btn">&#128196; View</a>
                            <% } else { %>
                                <span class="dim">—</span>
                            <% } %>
                        </td>
                    </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>

</main>

<!-- ═══ SCRIPT ═══ -->
<script>
    var ORDERS = <%- JSON.stringify(orders) %>;

    var PAL = ['#f5c842','#4fc3f7','#ff6f61','#56e39f','#c084fc','#f97316','#38bdf8','#fb7185'];
    var aCache = {};
    function aC(n) {
        if (!aCache[n]) { aCache[n] = PAL[Object.keys(aCache).length % PAL.length]; }
        return aCache[n];
    }

    Chart.defaults.color = '#6b6b8f';
    Chart.defaults.font  = { family: 'Outfit', size: 11 };
    var TT = { backgroundColor: '#1a1a26', borderColor: '#22223a', borderWidth: 1, padding: 10 };

    function freq(arr) {
        return arr.reduce(function(a, v) { a[v] = (a[v] || 0) + 1; return a; }, {});
    }
    function sortF(arr) {
        return Object.entries(freq(arr)).sort(function(a, b) { return b[1] - a[1]; });
    }

    // ── Build customer map (keyed by "name||phone") ───────
    // Groups all orders per unique customer identity
    var custMap = {};
    ORDERS.forEach(function(o) {
        var key = (o.client_name || 'Unknown').trim() + '||' + (o.phone || '').trim();
        if (!custMap[key]) {
            custMap[key] = {
                name:    (o.client_name || 'Unknown').trim(),
                phone:   (o.phone || '—').trim(),
                orders:  [],
                services: {}
            };
        }
        custMap[key].orders.push(o);
        if (o.service) { custMap[key].services[o.service] = true; }
    });

    // Sorted array of customers (most orders first)
    var CUSTOMERS = Object.values(custMap).sort(function(a, b) { return b.orders.length - a.orders.length; });

    // ── Widgets ───────────────────────────────────────────
    document.getElementById('wSvc').textContent      = new Set(ORDERS.map(function(o){ return o.service; }).filter(Boolean)).size;
    document.getElementById('wUrgent').textContent   = ORDERS.filter(function(o){ return o.notes && o.notes.toLowerCase().indexOf('urgent') !== -1; }).length;
    document.getElementById('wPickup').textContent   = ORDERS.filter(function(o){ return (o.delivery || '').toLowerCase() === 'pickup'; }).length;
    document.getElementById('wCustomers').textContent = CUSTOMERS.length;

    // ── Sender avatars in orders table ────────────────────
    document.querySelectorAll('.sender-av').forEach(function(el) {
        var n = el.dataset.name || '?';
        el.style.cssText = 'background:' + aC(n) + ';color:#0d0d14;width:22px;height:22px;border-radius:6px;font-size:10px;font-weight:700;display:inline-flex;align-items:center;justify-content:center;flex-shrink:0;font-family:Bebas Neue,sans-serif;';
        el.textContent = (n[0] || '?').toUpperCase();
    });

    // ── Service bar ───────────────────────────────────────
    if (ORDERS.length) {
        var sf = sortF(ORDERS.map(function(o){ return o.service || 'Unknown'; }));
        new Chart(document.getElementById('cService'), {
            type: 'bar',
            data: {
                labels: sf.map(function(e){ return e[0]; }),
                datasets: [{ data: sf.map(function(e){ return e[1]; }), backgroundColor: sf.map(function(_,i){ return PAL[i % PAL.length]; }), borderRadius: 6, borderSkipped: false }]
            },
            options: { responsive: true, plugins: { legend: { display: false }, tooltip: Object.assign({}, TT, { callbacks: { label: function(c){ return c.raw + ' orders'; } } }) }, scales: { x: { grid: { color: '#22223a' }, border: { color: '#22223a' } }, y: { grid: { color: '#22223a' }, border: { color: '#22223a' }, ticks: { stepSize: 1 } } } }
        });
    }

    // ── Delivery doughnut ─────────────────────────────────
    if (ORDERS.length) {
        var df = sortF(ORDERS.map(function(o){ return o.delivery || 'Unknown'; }));
        new Chart(document.getElementById('cDelivery'), {
            type: 'doughnut',
            data: {
                labels: df.map(function(e){ return e[0]; }),
                datasets: [{ data: df.map(function(e){ return e[1]; }), backgroundColor: PAL, borderColor: '#13131c', borderWidth: 3, hoverOffset: 7 }]
            },
            options: { responsive: true, cutout: '65%', plugins: { legend: { position: 'bottom', labels: { usePointStyle: true, pointStyleWidth: 8, padding: 10 } }, tooltip: TT } }
        });
    }

    // ── Time bar ──────────────────────────────────────────
    if (ORDERS.length) {
        var byDay = freq(ORDERS.map(function(o) {
            var d = new Date(o.created_at);
            return isNaN(d) ? 'Unknown' : d.toLocaleDateString('en-GB', { day: '2-digit', month: 'short' });
        }));
        new Chart(document.getElementById('cTime'), {
            type: 'bar',
            data: {
                labels: Object.keys(byDay),
                datasets: [{ data: Object.values(byDay), backgroundColor: 'rgba(79,195,247,.7)', borderRadius: 5, borderSkipped: false }]
            },
            options: { responsive: true, plugins: { legend: { display: false }, tooltip: Object.assign({}, TT, { callbacks: { label: function(c){ return c.raw + ' orders'; } } }) }, scales: { x: { grid: { display: false }, border: { color: '#22223a' }, ticks: { maxRotation: 35 } }, y: { grid: { color: '#22223a' }, border: { color: '#22223a' }, ticks: { stepSize: 1 } } } }
        });
    }

    // ── Sender leaderboard ────────────────────────────────
    (function() {
        if (!ORDERS.length) { document.getElementById('lbList').innerHTML = '<p style="color:var(--muted);font-size:13px">No data yet</p>'; return; }
        var sf = sortF(ORDERS.map(function(o){ return o.send || 'Unknown'; }));
        var max = sf[0] ? sf[0][1] : 1;
        document.getElementById('lbList').innerHTML = sf.map(function(entry, i) {
            var name = entry[0], count = entry[1];
            return '<div class="lb-row">' +
                '<span class="lb-rank' + (i === 0 ? ' g' : '') + '">' + (i + 1) + '</span>' +
                '<div class="lb-av" style="background:' + aC(name) + ';color:#0d0d14">' + (name[0] || '?').toUpperCase() + '</div>' +
                '<div style="flex:1"><div class="lb-name">' + name + '</div><div class="lb-detail">' + count + ' order' + (count > 1 ? 's' : '') + '</div></div>' +
                '<div class="lb-bar-wrap"><div class="lb-bar" style="width:' + Math.round(count / max * 100) + '%;background:' + aC(name) + '"></div></div>' +
                '<div class="lb-num" style="color:' + aC(name) + '">' + count + '</div>' +
                '</div>';
        }).join('');
    })();

    // ── Finishing tags + chart ────────────────────────────
    (function() {
        if (!ORDERS.length) return;
        var ff = sortF(ORDERS.map(function(o){ return o.finishing || 'None'; }));
        document.getElementById('fTags').innerHTML = ff.map(function(entry, i) {
            var c = PAL[i % PAL.length];
            return '<span class="ftag" style="color:' + c + ';border-color:' + c + '44;background:' + c + '11">' + entry[0] + '</span>';
        }).join('');
        new Chart(document.getElementById('cFinishing'), {
            type: 'bar',
            data: {
                labels: ff.map(function(e){ return e[0]; }),
                datasets: [{ data: ff.map(function(e){ return e[1]; }), backgroundColor: ff.map(function(_,i){ return PAL[i % PAL.length]; }), borderRadius: 5, borderSkipped: false }]
            },
            options: { indexAxis: 'y', responsive: true, plugins: { legend: { display: false }, tooltip: Object.assign({}, TT, { callbacks: { label: function(c){ return c.raw + ' orders'; } } }) }, scales: { x: { grid: { color: '#22223a' }, border: { color: '#22223a' }, ticks: { stepSize: 1 } }, y: { grid: { display: false }, border: { display: false } } } }
        });
    })();

    // ── Top 5 customers chart ─────────────────────────────
    (function() {
        if (!CUSTOMERS.length) return;
        var top5  = CUSTOMERS.slice(0, 5);
        var names = top5.map(function(c){ return c.name.split(' ')[0]; }); // first name to keep label short
        var vals  = top5.map(function(c){ return c.orders.length; });
        new Chart(document.getElementById('cTop5'), {
            type: 'bar',
            data: {
                labels: names,
                datasets: [{
                    label: 'Orders',
                    data: vals,
                    backgroundColor: top5.map(function(_, i){ return PAL[i % PAL.length]; }),
                    borderRadius: 8,
                    borderSkipped: false
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: { display: false },
                    tooltip: Object.assign({}, TT, {
                        callbacks: {
                            title: function(items){ return top5[items[0].dataIndex].name; },
                            label: function(c){ return c.raw + ' order' + (c.raw > 1 ? 's' : ''); }
                        }
                    })
                },
                scales: {
                    x: { grid: { display: false }, border: { color: '#22223a' } },
                    y: { grid: { color: '#22223a' }, border: { color: '#22223a' }, ticks: { stepSize: 1 } }
                }
            }
        });
    })();

    // ── Customer stats panel ──────────────────────────────
    (function() {
        if (!CUSTOMERS.length) return;
        var maxOrders = CUSTOMERS[0].orders.length;
        var totalOrders = ORDERS.length;
        var avgOrders = (totalOrders / CUSTOMERS.length).toFixed(1);
        var repeatCust = CUSTOMERS.filter(function(c){ return c.orders.length > 1; }).length;

        document.getElementById('custStats').innerHTML =
            '<div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-top:4px;">' +
                statBox('Most Active', CUSTOMERS[0].name.split(' ')[0], CUSTOMERS[0].orders.length + ' orders', '#f5c842') +
                statBox('Avg Orders/Customer', avgOrders, 'per unique customer', '#4fc3f7') +
                statBox('Repeat Customers', repeatCust, 'placed 2+ orders', '#56e39f') +
                statBox('Single-Order', CUSTOMERS.length - repeatCust, 'placed 1 order only', '#c084fc') +
            '</div>';
    })();

    function statBox(label, val, sub, color) {
        return '<div style="background:var(--card2);border:1px solid var(--line);border-radius:10px;padding:14px 16px;">' +
            '<div style="font-size:10px;text-transform:uppercase;letter-spacing:1.2px;color:var(--muted);margin-bottom:6px;">' + label + '</div>' +
            '<div style="font-family:Bebas Neue,sans-serif;font-size:28px;color:' + color + ';line-height:1;">' + val + '</div>' +
            '<div style="font-size:11px;color:var(--muted);margin-top:3px;">' + sub + '</div>' +
            '</div>';
    }

    // ── Customer table ────────────────────────────────────
    var ALL_CUSTOMERS = CUSTOMERS; // keep reference for export

    function renderCustomerRow(cust, rank) {
        var rankClass = rank === 1 ? 'rank-1' : rank === 2 ? 'rank-2' : rank === 3 ? 'rank-3' : 'rank-n';
        var services  = Object.keys(cust.services).join(', ') || '—';
        var orderNos  = cust.orders.map(function(o){ return '<span class="order-tag">' + o.order_no + '</span>'; }).join('');
        var latestDate = cust.orders.reduce(function(latest, o) {
            var d = new Date(o.created_at);
            return d > latest ? d : latest;
        }, new Date(0));
        var latestStr = isNaN(latestDate) ? '—' : latestDate.toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' });

        return '<tr data-cs="' + (cust.name + ' ' + cust.phone).toLowerCase() + '">' +
            '<td><span class="rank-badge ' + rankClass + '">' + rank + '</span></td>' +
            '<td><div class="cn" style="display:flex;align-items:center;gap:8px;">' +
                '<span style="width:28px;height:28px;border-radius:8px;background:' + aC(cust.name) + ';color:#0d0d14;display:inline-flex;align-items:center;justify-content:center;font-weight:700;font-size:12px;font-family:Bebas Neue,sans-serif;flex-shrink:0;">' + (cust.name[0] || '?').toUpperCase() + '</span>' +
                cust.name + '</div></td>' +
            '<td class="dim">' + cust.phone + '</td>' +
            '<td><span style="font-family:Bebas Neue,sans-serif;font-size:22px;color:' + PAL[(rank-1) % PAL.length] + '">' + cust.orders.length + '</span></td>' +
            '<td class="dim">' + services + '</td>' +
            '<td><div class="cust-orders">' + orderNos + '</div></td>' +
            '<td class="dim">' + latestStr + '</td>' +
            '</tr>';
    }

    function buildCustomerTable(customers) {
        document.getElementById('custCount').textContent = '(' + customers.length + ' of ' + CUSTOMERS.length + ')';
        document.getElementById('custBody').innerHTML = customers.map(function(cust, i) {
            return renderCustomerRow(cust, i + 1);
        }).join('');
    }

    buildCustomerTable(CUSTOMERS);

    function filterCustomers() {
        var q = document.getElementById('custSearch').value.toLowerCase();
        var filtered = !q ? CUSTOMERS : CUSTOMERS.filter(function(c) {
            return (c.name + ' ' + c.phone).toLowerCase().indexOf(q) !== -1;
        });
        buildCustomerTable(filtered);
    }

    // ── Orders table search ───────────────────────────────
    function filterTable() {
        var q = document.getElementById('srchInput').value.toLowerCase();
        var rows = document.querySelectorAll('#tBody tr');
        var visible = 0;
        rows.forEach(function(row) {
            var show = !q || row.dataset.s.indexOf(q) !== -1;
            row.style.display = show ? '' : 'none';
            if (show) visible++;
        });
        document.getElementById('tCount').textContent = '(' + visible + ' of ' + ORDERS.length + ')';
    }

    // ── CSV helpers ───────────────────────────────────────
    function escCSV(val) {
        var s = String(val === null || val === undefined ? '' : val);
        if (s.indexOf(',') !== -1 || s.indexOf('"') !== -1 || s.indexOf('\n') !== -1) {
            s = '"' + s.replace(/"/g, '""') + '"';
        }
        return s;
    }

    function downloadCSV(filename, rows) {
        var csv = rows.map(function(row) {
            return row.map(escCSV).join(',');
        }).join('\n');
        var blob = new Blob(['\uFEFF' + csv], { type: 'text/csv;charset=utf-8;' });
        var url  = URL.createObjectURL(blob);
        var a    = document.createElement('a');
        a.href     = url;
        a.download = filename;
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
        URL.revokeObjectURL(url);
    }

    // ── Export: Orders CSV ────────────────────────────────
    function exportOrdersCSV() {
        var header = ['Order No','Client Name','Phone','Service','Product','Quantity','Paper','Finishing','Deadline','Delivery','Sender','Notes','PDF Link','Created At'];
        var rows = [header];
        ORDERS.forEach(function(o) {
            rows.push([
                o.order_no, o.client_name, o.phone, o.service, o.product,
                o.quantity, o.paper, o.finishing, o.deadline, o.delivery,
                o.send, o.notes, o.pdf_link, o.created_at
            ]);
        });
        downloadCSV('orders_export_' + today() + '.csv', rows);
    }

    // ── Export: Customer Report CSV ───────────────────────
    function exportCustomerCSV() {
        var header = ['Rank','Customer Name','Phone','Total Orders','Order Numbers','Services Used','Latest Order','Repeat Customer'];
        var rows = [header];
        CUSTOMERS.forEach(function(cust, i) {
            var orderNos = cust.orders.map(function(o){ return o.order_no; }).join(' | ');
            var services = Object.keys(cust.services).join(' | ');
            var latestDate = cust.orders.reduce(function(latest, o) {
                var d = new Date(o.created_at);
                return d > latest ? d : latest;
            }, new Date(0));
            var latestStr = isNaN(latestDate) ? '' : latestDate.toLocaleDateString('en-GB');
            rows.push([
                i + 1,
                cust.name,
                cust.phone,
                cust.orders.length,
                orderNos,
                services,
                latestStr,
                cust.orders.length > 1 ? 'Yes' : 'No'
            ]);
        });
        downloadCSV('customer_report_' + today() + '.csv', rows);
    }

    function today() {
        return new Date().toISOString().slice(0, 10).replace(/-/g, '');
    }
</script>
</body>
</html>