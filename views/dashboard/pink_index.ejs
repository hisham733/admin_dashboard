<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Orders Dashboard</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
    <style>
        :root {
            --bg:       #ede0f7;
            --bg2:      #e2d0f0;
            --glass:    rgba(255,255,255,0.55);
            --glass2:   rgba(255,255,255,0.35);
            --border:   rgba(255,255,255,0.7);
            --rose:     #e06fa0;
            --rose2:    #f48cb1;
            --violet:   #9b6fd4;
            --violet2:  #c09ee8;
            --peach:    #f5a8c0;
            --lavender: #b89de0;
            --mint:     #a8d8c8;
            --sky:      #93c5e8;
            --text:     #3d2c5e;
            --muted:    #9b87b8;
            --shadow:   rgba(130,80,180,0.15);
            --shadow2:  rgba(200,100,160,0.2);
            --r:        20px;
        }
        * { margin:0; padding:0; box-sizing:border-box; }
        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--bg);
            color: var(--text);
            min-height: 100vh;
            position: relative;
            overflow-x: hidden;
        }

        /* ── Dreamy background blobs ── */
        body::before {
            content: '';
            position: fixed;
            width: 600px; height: 600px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(224,111,160,0.25) 0%, transparent 70%);
            top: -150px; left: -150px;
            pointer-events: none;
            z-index: 0;
        }
        body::after {
            content: '';
            position: fixed;
            width: 500px; height: 500px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(155,111,212,0.2) 0%, transparent 70%);
            bottom: -100px; right: -100px;
            pointer-events: none;
            z-index: 0;
        }
        .blob3 {
            position: fixed;
            width: 400px; height: 400px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(147,197,232,0.18) 0%, transparent 70%);
            top: 40%; left: 50%;
            transform: translate(-50%,-50%);
            pointer-events: none;
            z-index: 0;
        }

        main, header { position: relative; z-index: 1; }

        /* ── Header ── */
        .hdr {
            padding: 28px 40px;
            background: var(--glass);
            backdrop-filter: blur(20px);
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 16px;
            box-shadow: 0 4px 30px var(--shadow);
        }
        .hdr-left { display: flex; align-items: center; gap: 16px; }
        .hdr-icon {
            width: 48px; height: 48px;
            border-radius: 14px;
            background: linear-gradient(135deg, var(--rose), var(--violet));
            display: flex; align-items: center; justify-content: center;
            font-size: 22px;
            box-shadow: 0 4px 16px var(--shadow2);
        }
        .hdr h1 {
            font-family: 'Playfair Display', serif;
            font-size: clamp(22px, 3vw, 36px);
            color: var(--text);
            font-weight: 700;
            line-height: 1.1;
        }
        .hdr h1 em { color: var(--rose); font-style: italic; }
        .hdr p { font-size: 12px; color: var(--muted); margin-top: 2px; }

        .live-pill {
            display: inline-flex; align-items: center; gap: 7px;
            padding: 8px 16px;
            border-radius: 30px;
            background: rgba(255,255,255,0.6);
            border: 1px solid var(--border);
            font-size: 12px; color: var(--violet);
            box-shadow: 0 2px 12px var(--shadow);
            font-weight: 500;
        }
        .live-dot {
            width: 7px; height: 7px; border-radius: 50%;
            background: var(--rose);
            box-shadow: 0 0 7px var(--rose);
            animation: pulse 1.6s infinite;
        }
        @keyframes pulse { 0%,100%{opacity:1;transform:scale(1);} 50%{opacity:.5;transform:scale(0.8);} }

        /* ── Layout ── */
        .wrap { padding: 32px 40px; }
        .section-label {
            font-size: 11px; font-weight: 600;
            letter-spacing: 3px; text-transform: uppercase;
            color: var(--muted);
            margin-bottom: 16px;
            display: flex; align-items: center; gap: 12px;
        }
        .section-label::after {
            content: ''; flex: 1; height: 1px;
            background: linear-gradient(90deg, rgba(155,111,212,0.3), transparent);
        }

        /* ── Glass card base ── */
        .glass {
            background: var(--glass);
            backdrop-filter: blur(16px);
            border: 1px solid var(--border);
            border-radius: var(--r);
            box-shadow: 0 8px 32px var(--shadow), inset 0 1px 0 rgba(255,255,255,0.6);
        }

        /* ── Widgets ── */
        .widgets { display: grid; grid-template-columns: repeat(5,1fr); gap: 16px; margin-bottom: 28px; }
        .w {
            background: var(--glass);
            backdrop-filter: blur(16px);
            border: 1px solid var(--border);
            border-radius: var(--r);
            padding: 20px 22px;
            box-shadow: 0 8px 32px var(--shadow), inset 0 1px 0 rgba(255,255,255,0.7);
            animation: fadeUp .5s both;
            transition: transform .2s, box-shadow .2s;
            position: relative;
            overflow: hidden;
        }
        .w::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0; height: 3px;
            border-radius: var(--r) var(--r) 0 0;
        }
        .w:nth-child(1)::before { background: linear-gradient(90deg, var(--rose), var(--peach)); }
        .w:nth-child(2)::before { background: linear-gradient(90deg, var(--violet), var(--lavender)); }
        .w:nth-child(3)::before { background: linear-gradient(90deg, #f06292, var(--rose)); }
        .w:nth-child(4)::before { background: linear-gradient(90deg, var(--mint), var(--sky)); }
        .w:nth-child(5)::before { background: linear-gradient(90deg, var(--sky), var(--lavender)); }
        .w:hover { transform: translateY(-3px); box-shadow: 0 14px 40px var(--shadow2); }
        .w:nth-child(1){animation-delay:.05s;}.w:nth-child(2){animation-delay:.1s;}.w:nth-child(3){animation-delay:.15s;}.w:nth-child(4){animation-delay:.2s;}.w:nth-child(5){animation-delay:.25s;}
        .w-icon { font-size: 20px; margin-bottom: 10px; }
        .w-label { font-size: 10px; text-transform: uppercase; letter-spacing: 1.5px; color: var(--muted); margin-bottom: 4px; font-weight: 600; }
        .w-val { font-family: 'Playfair Display', serif; font-size: 36px; line-height: 1; font-weight: 700; }
        .w:nth-child(1) .w-val { color: var(--rose); }
        .w:nth-child(2) .w-val { color: var(--violet); }
        .w:nth-child(3) .w-val { color: #e05090; }
        .w:nth-child(4) .w-val { color: #5dab8a; }
        .w:nth-child(5) .w-val { color: var(--sky); }
        .w-sub { font-size: 11px; color: var(--muted); margin-top: 4px; }

        /* ── Cards ── */
        .card {
            background: var(--glass);
            backdrop-filter: blur(16px);
            border: 1px solid var(--border);
            border-radius: var(--r);
            padding: 24px 26px;
            box-shadow: 0 8px 32px var(--shadow), inset 0 1px 0 rgba(255,255,255,0.6);
            animation: fadeUp .5s both;
        }
        .card-title { font-family: 'Playfair Display', serif; font-size: 18px; color: var(--text); margin-bottom: 2px; font-weight: 700; }
        .card-sub { font-size: 11px; color: var(--muted); margin-bottom: 18px; }

        .row3 { display: grid; grid-template-columns: 1.7fr 1fr 1fr; gap: 16px; margin-bottom: 28px; }
        .row3 .card:nth-child(1){animation-delay:.3s;}.row3 .card:nth-child(2){animation-delay:.35s;}.row3 .card:nth-child(3){animation-delay:.4s;}
        .row2 { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 28px; }
        .row2 .card:nth-child(1){animation-delay:.45s;}.row2 .card:nth-child(2){animation-delay:.5s;}
        .row2b { display: grid; grid-template-columns: 1.2fr 1fr; gap: 16px; margin-bottom: 28px; }
        .row2b .card:nth-child(1){animation-delay:.5s;}.row2b .card:nth-child(2){animation-delay:.55s;}

        /* ── Leaderboard ── */
        .lb-row { display: flex; align-items: center; gap: 10px; padding: 10px 0; border-bottom: 1px solid rgba(155,111,212,0.12); }
        .lb-row:last-child { border: none; }
        .lb-rank { font-family: 'Playfair Display', serif; font-size: 18px; width: 22px; color: var(--muted); font-weight: 700; }
        .lb-rank.g { color: var(--rose); }
        .lb-av { width: 30px; height: 30px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 12px; flex-shrink: 0; color: #fff; }
        .lb-name { flex: 1; font-size: 13px; font-weight: 500; color: var(--text); }
        .lb-detail { font-size: 11px; color: var(--muted); }
        .lb-bar-wrap { width: 70px; height: 4px; background: rgba(155,111,212,0.15); border-radius: 2px; overflow: hidden; }
        .lb-bar { height: 100%; border-radius: 2px; }
        .lb-num { font-family: 'Playfair Display', serif; font-size: 18px; width: 24px; text-align: right; font-weight: 700; }

        /* ── Tag cloud ── */
        .tag-cloud { display: flex; flex-wrap: wrap; gap: 7px; margin-bottom: 14px; }
        .ftag { padding: 5px 13px; border-radius: 20px; font-size: 11px; font-weight: 600; border: 1px solid; }

        /* ── Buttons ── */
        .export-btn {
            display: inline-flex; align-items: center; gap: 6px;
            padding: 8px 16px; border-radius: 12px;
            font-size: 12px; font-weight: 600;
            background: rgba(255,255,255,0.6);
            border: 1px solid rgba(224,111,160,0.3);
            color: var(--rose); cursor: pointer;
            transition: all .2s;
            font-family: 'DM Sans', sans-serif;
            box-shadow: 0 2px 12px rgba(224,111,160,0.1);
        }
        .export-btn:hover { background: rgba(255,255,255,0.85); box-shadow: 0 4px 20px rgba(224,111,160,0.2); transform: translateY(-1px); }
        .export-btn-mint { border-color: rgba(93,171,138,0.3); color: #5dab8a; box-shadow: 0 2px 12px rgba(93,171,138,0.1); }
        .export-btn-mint:hover { box-shadow: 0 4px 20px rgba(93,171,138,0.2); }

        /* ── Table card ── */
        .tbl-card {
            background: var(--glass);
            backdrop-filter: blur(16px);
            border: 1px solid var(--border);
            border-radius: var(--r);
            overflow: hidden;
            box-shadow: 0 8px 32px var(--shadow), inset 0 1px 0 rgba(255,255,255,0.6);
            animation: fadeUp .5s .55s both;
        }
        .tbl-toolbar {
            display: flex; align-items: center; justify-content: space-between;
            padding: 18px 26px;
            border-bottom: 1px solid rgba(155,111,212,0.12);
            gap: 12px; flex-wrap: wrap;
            background: rgba(255,255,255,0.3);
        }
        .tbl-left { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; }
        .tbl-title { font-family: 'Playfair Display', serif; font-size: 20px; color: var(--text); font-weight: 700; }
        .tbl-count { font-size: 12px; color: var(--muted); }
        .srch-box {
            display: flex; align-items: center; gap: 8px;
            background: rgba(255,255,255,0.55);
            border: 1px solid rgba(155,111,212,0.2);
            border-radius: 12px; padding: 8px 14px;
            width: 260px;
            box-shadow: inset 0 1px 3px rgba(0,0,0,0.04);
        }
        .srch-box input { background: none; border: none; outline: none; color: var(--text); font-family: 'DM Sans', sans-serif; font-size: 13px; width: 100%; }
        .srch-box input::placeholder { color: var(--muted); }

        /* ── Tables ── */
        .tbl-wrap { overflow-x: auto; }
        table { width: 100%; border-collapse: collapse; }
        thead th {
            padding: 12px 18px;
            text-align: left; font-size: 10px; font-weight: 700;
            text-transform: uppercase; letter-spacing: 1.5px;
            color: var(--muted);
            background: rgba(255,255,255,0.25);
            border-bottom: 1px solid rgba(155,111,212,0.12);
            white-space: nowrap;
        }
        tbody tr { border-bottom: 1px solid rgba(155,111,212,0.08); transition: background .15s; }
        tbody tr:last-child { border: none; }
        tbody tr:hover { background: rgba(255,255,255,0.3); }
        tbody td { padding: 12px 18px; font-size: 13px; vertical-align: middle; }
        .ord-no { font-family: 'Playfair Display', serif; font-size: 16px; color: var(--rose); font-weight: 700; }
        .cn { font-weight: 600; color: var(--text); }
        .cp { font-size: 11px; color: var(--muted); margin-top: 2px; }
        .chip {
            display: inline-block; padding: 4px 10px;
            border-radius: 20px; font-size: 11px; font-weight: 600;
            background: rgba(155,111,212,0.1);
            border: 1px solid rgba(155,111,212,0.2);
            color: var(--violet);
        }
        .pdf-btn {
            display: inline-flex; align-items: center; gap: 4px;
            padding: 5px 11px; border-radius: 10px; font-size: 11px; font-weight: 600;
            background: rgba(224,111,160,0.1);
            border: 1px solid rgba(224,111,160,0.25);
            color: var(--rose); text-decoration: none; transition: all .2s;
        }
        .pdf-btn:hover { background: rgba(224,111,160,0.2); transform: translateY(-1px); }
        .del-btn {
            display: inline-flex; align-items: center; gap: 4px;
            padding: 5px 11px; border-radius: 10px; font-size: 11px; font-weight: 600;
            background: rgba(240,98,146,.08);
            border: 1px solid rgba(240,98,146,.2);
            color: #e05090; text-decoration: none; transition: all .2s;
        }
        .urgent-dot {
            display: inline-block; width: 6px; height: 6px; border-radius: 50%;
            background: var(--rose); box-shadow: 0 0 6px var(--rose);
            margin-right: 5px; animation: pulse 1.4s infinite;
        }
        td.dim { color: var(--muted); font-size: 12px; }

        /* ── Customer table ── */
        .cust-orders { display: flex; flex-wrap: wrap; gap: 4px; }
        .order-tag {
            padding: 3px 8px; border-radius: 6px; font-size: 10px; font-weight: 600;
            background: rgba(224,111,160,0.1);
            border: 1px solid rgba(224,111,160,0.2);
            color: var(--rose);
        }
        .rank-badge {
            display: inline-flex; align-items: center; justify-content: center;
            width: 24px; height: 24px; border-radius: 8px;
            font-size: 12px; font-weight: 700;
        }
        .rank-1 { background: rgba(224,111,160,0.15); color: var(--rose); }
        .rank-2 { background: rgba(155,111,212,0.12); color: var(--violet); }
        .rank-3 { background: rgba(147,197,232,0.15); color: var(--sky); }
        .rank-n { background: rgba(155,111,212,0.07); color: var(--muted); }

        /* ── Overlay / Modal ── */
        .fab {
            position: fixed; bottom: 28px; right: 28px;
            width: 52px; height: 52px; border-radius: 50%;
            background: linear-gradient(135deg, var(--rose), var(--violet));
            border: none; cursor: pointer; font-size: 24px;
            display: flex; align-items: center; justify-content: center; color: #fff;
            box-shadow: 0 6px 24px rgba(224,111,160,.4);
            transition: all .2s; z-index: 100;
        }
        .fab:hover { transform: scale(1.1); box-shadow: 0 10px 32px rgba(224,111,160,.55); }
        .overlay {
            position: fixed; inset: 0;
            background: rgba(61,44,94,0.4);
            backdrop-filter: blur(8px);
            z-index: 200; display: none;
            align-items: center; justify-content: center;
        }
        .overlay.open { display: flex; }
        .modal {
            background: rgba(255,255,255,0.85);
            backdrop-filter: blur(20px);
            border: 1px solid var(--border);
            border-radius: 24px; padding: 34px;
            width: 560px; max-width: 95vw; max-height: 90vh; overflow-y: auto;
            box-shadow: 0 24px 80px rgba(130,80,180,0.25);
            animation: modalIn .3s cubic-bezier(.34,1.56,.64,1);
        }
        @keyframes modalIn { from{opacity:0;transform:scale(.92) translateY(20px);} to{opacity:1;transform:scale(1) translateY(0);} }
        .modal-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 24px; }
        .modal-title { font-family: 'Playfair Display', serif; font-size: 26px; color: var(--text); font-weight: 700; }
        .modal-close {
            width: 32px; height: 32px; border-radius: 10px;
            border: 1px solid rgba(155,111,212,0.2);
            background: rgba(255,255,255,0.6); color: var(--muted);
            cursor: pointer; font-size: 16px;
            display: flex; align-items: center; justify-content: center; transition: all .2s;
        }
        .modal-close:hover { color: var(--text); background: rgba(255,255,255,0.9); }
        .fgrid { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
        .fg { display: flex; flex-direction: column; gap: 6px; }
        .fg.full { grid-column: span 2; }
        .flabel { font-size: 10px; text-transform: uppercase; letter-spacing: 1.5px; color: var(--muted); font-weight: 600; }
        .finput {
            padding: 10px 14px;
            background: rgba(255,255,255,0.7);
            border: 1px solid rgba(155,111,212,0.2);
            border-radius: 12px; color: var(--text);
            font-family: 'DM Sans', sans-serif; font-size: 13px;
            outline: none; transition: border-color .2s, box-shadow .2s;
        }
        .finput:focus { border-color: var(--rose); box-shadow: 0 0 0 3px rgba(224,111,160,0.12); }
        .finput::placeholder { color: var(--muted); }
        .form-actions { display: flex; justify-content: flex-end; gap: 10px; margin-top: 24px; }
        .btn-cancel {
            padding: 10px 20px; border-radius: 12px;
            border: 1px solid rgba(155,111,212,0.2);
            background: rgba(255,255,255,0.6); color: var(--muted);
            font-family: 'DM Sans', sans-serif; font-size: 13px; cursor: pointer; transition: all .2s;
        }
        .btn-cancel:hover { color: var(--text); background: rgba(255,255,255,0.9); }
        .btn-submit {
            padding: 10px 26px; border-radius: 12px; border: none;
            background: linear-gradient(135deg, var(--rose), var(--violet));
            color: #fff; font-family: 'Playfair Display', serif; font-size: 16px;
            cursor: pointer; transition: all .2s;
            box-shadow: 0 4px 16px rgba(224,111,160,0.35);
        }
        .btn-submit:hover { box-shadow: 0 6px 24px rgba(224,111,160,0.5); transform: translateY(-1px); }

        @keyframes fadeUp { from{opacity:0;transform:translateY(16px);} to{opacity:1;transform:translateY(0);} }
        ::-webkit-scrollbar { width: 5px; height: 5px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: rgba(155,111,212,0.3); border-radius: 3px; }

        @media(max-width:1200px){.widgets{grid-template-columns:repeat(3,1fr);}.row3{grid-template-columns:1fr 1fr;}.row3 .card:first-child{grid-column:span 2;}}
        @media(max-width:860px){.widgets{grid-template-columns:1fr 1fr;}.row3,.row2,.row2b{grid-template-columns:1fr;}.row3 .card:first-child{grid-column:span 1;}.wrap{padding:20px 16px;}.hdr{padding:20px 16px;}}
    </style>
</head>
<body>
<div class="blob3"></div>

<!-- ═══ HEADER ═══ -->
<header class="hdr">
    <div class="hdr-left">
        <div class="hdr-icon">📦</div>
        <div>
            <h1>Orders <em>Dashboard</em></h1>
            <p>Source: <strong>orders</strong> table</p>
        </div>
    </div>
    <div class="live-pill">
        <span class="live-dot"></span>
        <%= orders.length %> records
    </div>
</header>

<main class="wrap">

    <!-- ═══ OVERVIEW WIDGETS ═══ -->
    <div class="section-label">Overview</div>
    <div class="widgets">
        <div class="w">
            <div class="w-icon">📦</div>
            <div class="w-label">Total Orders</div>
            <div class="w-val"><%= orders.length %></div>
            <div class="w-sub">All records</div>
        </div>
        <div class="w">
            <div class="w-icon">🖨️</div>
            <div class="w-label">Services</div>
            <div class="w-val" id="wSvc">—</div>
            <div class="w-sub">Unique types</div>
        </div>
        <div class="w">
            <div class="w-icon">🚨</div>
            <div class="w-label">Urgent</div>
            <div class="w-val" id="wUrgent">—</div>
            <div class="w-sub">Flagged in notes</div>
        </div>
        <div class="w">
            <div class="w-icon">📬</div>
            <div class="w-label">Pickup</div>
            <div class="w-val" id="wPickup">—</div>
            <div class="w-sub">Delivery method</div>
        </div>
        <div class="w">
            <div class="w-icon">👤</div>
            <div class="w-label">Unique Customers</div>
            <div class="w-val" id="wCustomers">—</div>
            <div class="w-sub">By name + phone</div>
        </div>
    </div>

    <!-- ═══ ORDER CHARTS ═══ -->
    <div class="section-label">Order Analytics</div>
    <div class="row3">
        <div class="card">
            <div class="card-title">Orders by Service</div>
            <div class="card-sub">Volume per service type</div>
            <canvas id="cService"></canvas>
        </div>
        <div class="card">
            <div class="card-title">Delivery Method</div>
            <div class="card-sub">Pickup vs courier split</div>
            <canvas id="cDelivery"></canvas>
        </div>
        <div class="card">
            <div class="card-title">Orders by Date</div>
            <div class="card-sub">Grouped by creation day</div>
            <canvas id="cTime"></canvas>
        </div>
    </div>

    <div class="row2">
        <div class="card">
            <div class="card-title">Sender Leaderboard</div>
            <div class="card-sub">Orders submitted per sender</div>
            <div id="lbList"></div>
        </div>
        <div class="card">
            <div class="card-title">Finishing Types</div>
            <div class="card-sub">Methods used across orders</div>
            <div class="tag-cloud" id="fTags"></div>
            <canvas id="cFinishing"></canvas>
        </div>
    </div>

    <!-- ═══ CUSTOMER SECTION ═══ -->
    <div class="section-label">Customer Analysis</div>
    <div class="row2b">
        <div class="card">
            <div class="card-title">Top 5 Customers</div>
            <div class="card-sub">By number of orders placed</div>
            <canvas id="cTop5"></canvas>
        </div>
        <div class="card">
            <div class="card-title">Customer Stats</div>
            <div class="card-sub">Breakdown at a glance</div>
            <div id="custStats"></div>
        </div>
    </div>

    <!-- Customer full table -->
    <div class="tbl-card" style="margin-bottom:28px;">
        <div class="tbl-toolbar">
            <div class="tbl-left">
                <span class="tbl-title">Customer Report</span>
                <span class="tbl-count" id="custCount"></span>
            </div>
            <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;">
                <div class="srch-box">
                    <span style="color:var(--muted)">⌕</span>
                    <input type="text" id="custSearch" placeholder="Search customer…" oninput="filterCustomers()">
                </div>
                <button class="export-btn export-btn-mint" onclick="exportCustomerCSV()">↓ Export Customer Report</button>
            </div>
        </div>
        <div class="tbl-wrap">
            <table id="custTable">
                <thead>
                    <tr>
                        <th>Rank</th><th>Customer</th><th>Phone</th>
                        <th>Total Orders</th><th>Services Used</th>
                        <th>Order Numbers</th><th>Latest Order</th>
                    </tr>
                </thead>
                <tbody id="custBody"></tbody>
            </table>
        </div>
    </div>

    <!-- ═══ ORDERS TABLE ═══ -->
    <div class="section-label">Orders</div>
    <div class="tbl-card">
        <div class="tbl-toolbar">
            <div class="tbl-left">
                <span class="tbl-title">All Orders</span>
                <span class="tbl-count" id="tCount">(<%= orders.length %>)</span>
            </div>
            <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;">
                <div class="srch-box">
                    <span style="color:var(--muted)">⌕</span>
                    <input type="text" id="srchInput" placeholder="Search order, client, product…" oninput="filterTable()">
                </div>
                <button class="export-btn" onclick="exportOrdersCSV()">↓ Export Orders CSV</button>
            </div>
        </div>
        <div class="tbl-wrap">
            <table>
                <thead>
                    <tr>
                        <th>Order #</th><th>Client</th><th>Service</th><th>Product</th>
                        <th>Qty</th><th>Paper</th><th>Finishing</th><th>Deadline</th>
                        <th>Delivery</th><th>Sender</th><th>Notes</th><th>PDF</th>
                    </tr>
                </thead>
                <tbody id="tBody">
                    <% for (var i = 0; i < orders.length; i++) { %>
                    <%
                        var o = orders[i];
                        var searchStr = [o.order_no, o.client_name, o.phone, o.service, o.product, o.send, o.finishing, o.delivery, o.paper].join(' ');
                        var isUrgent = o.notes && o.notes.toLowerCase().indexOf('urgent') !== -1;
                        var safeNotes = o.notes ? o.notes.substring(0, 55) : '';
                    %>
                    <tr data-s="<%= searchStr.toLowerCase() %>">
                        <td><span class="ord-no"><%= o.order_no %></span></td>
                        <td>
                            <div class="cn"><% if (isUrgent) { %><span class="urgent-dot"></span><% } %><%= o.client_name %></div>
                            <div class="cp"><%= o.phone || '' %></div>
                        </td>
                        <td><span class="chip"><%= o.service || '—' %></span></td>
                        <td style="max-width:150px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis"><%= o.product || '—' %></td>
                        <td style="text-align:center"><%= o.quantity || '—' %></td>
                        <td class="dim"><%= o.paper || '—' %></td>
                        <td><span class="chip"><%= o.finishing || '—' %></span></td>
                        <td style="white-space:nowrap"><%= o.deadline || '—' %></td>
                        <td><%= o.delivery || '—' %></td>
                        <td>
                            <span style="display:inline-flex;align-items:center;gap:7px;">
                                <span class="sender-av" data-name="<%= o.send || '' %>"></span>
                                <%= o.send || '—' %>
                            </span>
                        </td>
                        <td class="dim" style="max-width:150px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">
                            <%= safeNotes %><% if (o.notes && o.notes.length > 55) { %>…<% } %>
                        </td>
                        <td>
                            <% if (o.pdf_link) { %>
                                <a href="<%= o.pdf_link %>" target="_blank" class="pdf-btn">📄 View</a>
                            <% } else { %>
                                <span class="dim">—</span>
                            <% } %>
                        </td>
                    </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>

</main>

<!-- ═══ SCRIPT ═══ -->
<script>
    var ORDERS = <%- JSON.stringify(orders) %>;

    var PAL = ['#e06fa0','#9b6fd4','#f5a8c0','#93c5e8','#b89de0','#5dab8a','#f8b4c8','#c084fc'];
    var aCache = {};
    function aC(n) {
        if (!aCache[n]) { aCache[n] = PAL[Object.keys(aCache).length % PAL.length]; }
        return aCache[n];
    }

    Chart.defaults.color = '#9b87b8';
    Chart.defaults.font  = { family: 'DM Sans', size: 11 };
    var TT = { backgroundColor: 'rgba(255,255,255,0.9)', borderColor: 'rgba(155,111,212,0.2)', borderWidth: 1, padding: 12, titleColor: '#3d2c5e', bodyColor: '#6b5590', cornerRadius: 10 };

    function freq(arr) { return arr.reduce(function(a, v){ a[v] = (a[v]||0)+1; return a; }, {}); }
    function sortF(arr) { return Object.entries(freq(arr)).sort(function(a,b){ return b[1]-a[1]; }); }

    var custMap = {};
    ORDERS.forEach(function(o) {
        var key = (o.client_name||'Unknown').trim()+'||'+(o.phone||'').trim();
        if (!custMap[key]) { custMap[key] = { name:(o.client_name||'Unknown').trim(), phone:(o.phone||'—').trim(), orders:[], services:{} }; }
        custMap[key].orders.push(o);
        if (o.service) { custMap[key].services[o.service] = true; }
    });
    var CUSTOMERS = Object.values(custMap).sort(function(a,b){ return b.orders.length - a.orders.length; });

    document.getElementById('wSvc').textContent      = new Set(ORDERS.map(function(o){ return o.service; }).filter(Boolean)).size;
    document.getElementById('wUrgent').textContent   = ORDERS.filter(function(o){ return o.notes && o.notes.toLowerCase().indexOf('urgent')!==-1; }).length;
    document.getElementById('wPickup').textContent   = ORDERS.filter(function(o){ return (o.delivery||'').toLowerCase()==='pickup'; }).length;
    document.getElementById('wCustomers').textContent = CUSTOMERS.length;

    document.querySelectorAll('.sender-av').forEach(function(el) {
        var n = el.dataset.name || '?';
        el.style.cssText = 'background:linear-gradient(135deg,'+aC(n)+','+PAL[(PAL.indexOf(aC(n))+1)%PAL.length]+');color:#fff;width:24px;height:24px;border-radius:8px;font-size:10px;font-weight:700;display:inline-flex;align-items:center;justify-content:center;flex-shrink:0;';
        el.textContent = (n[0]||'?').toUpperCase();
    });

    if (ORDERS.length) {
        var sf = sortF(ORDERS.map(function(o){ return o.service||'Unknown'; }));
        new Chart(document.getElementById('cService'), {
            type:'bar',
            data:{ labels:sf.map(function(e){return e[0];}), datasets:[{ data:sf.map(function(e){return e[1];}), backgroundColor:sf.map(function(_,i){return PAL[i%PAL.length]+'cc';}), borderRadius:10, borderSkipped:false }] },
            options:{ responsive:true, plugins:{ legend:{display:false}, tooltip:Object.assign({},TT,{callbacks:{label:function(c){return c.raw+' orders';}}}) }, scales:{ x:{grid:{color:'rgba(155,111,212,0.08)'},border:{color:'rgba(155,111,212,0.08)'}}, y:{grid:{color:'rgba(155,111,212,0.08)'},border:{color:'rgba(155,111,212,0.08)'},ticks:{stepSize:1}} } }
        });
    }

    if (ORDERS.length) {
        var df = sortF(ORDERS.map(function(o){ return o.delivery||'Unknown'; }));
        new Chart(document.getElementById('cDelivery'), {
            type:'doughnut',
            data:{ labels:df.map(function(e){return e[0];}), datasets:[{ data:df.map(function(e){return e[1];}), backgroundColor:PAL, borderColor:'rgba(255,255,255,0.7)', borderWidth:3, hoverOffset:8 }] },
            options:{ responsive:true, cutout:'65%', plugins:{ legend:{ position:'bottom', labels:{ usePointStyle:true, pointStyleWidth:8, padding:12, color:'#9b87b8' } }, tooltip:TT } }
        });
    }

    if (ORDERS.length) {
        var byDay = freq(ORDERS.map(function(o){ var d=new Date(o.created_at); return isNaN(d)?'Unknown':d.toLocaleDateString('en-GB',{day:'2-digit',month:'short'}); }));
        new Chart(document.getElementById('cTime'), {
            type:'bar',
            data:{ labels:Object.keys(byDay), datasets:[{ data:Object.values(byDay), backgroundColor:'rgba(224,111,160,0.6)', borderRadius:8, borderSkipped:false }] },
            options:{ responsive:true, plugins:{ legend:{display:false}, tooltip:Object.assign({},TT,{callbacks:{label:function(c){return c.raw+' orders';}}}) }, scales:{ x:{grid:{display:false},border:{color:'rgba(155,111,212,0.08)'},ticks:{maxRotation:35}}, y:{grid:{color:'rgba(155,111,212,0.08)'},border:{color:'rgba(155,111,212,0.08)'},ticks:{stepSize:1}} } }
        });
    }

    (function() {
        if (!ORDERS.length) { document.getElementById('lbList').innerHTML = '<p style="color:var(--muted);font-size:13px">No data yet</p>'; return; }
        var sf = sortF(ORDERS.map(function(o){ return o.send||'Unknown'; }));
        var max = sf[0] ? sf[0][1] : 1;
        document.getElementById('lbList').innerHTML = sf.map(function(entry, i) {
            var name=entry[0], count=entry[1];
            return '<div class="lb-row">'+
                '<span class="lb-rank'+(i===0?' g':'')+'">'+(''+[1,2,3][i]||i+1)+'</span>'+
                '<div class="lb-av" style="background:linear-gradient(135deg,'+aC(name)+','+PAL[(i+1)%PAL.length]+')">'+(name[0]||'?').toUpperCase()+'</div>'+
                '<div style="flex:1"><div class="lb-name">'+name+'</div><div class="lb-detail">'+count+' order'+(count>1?'s':'')+'</div></div>'+
                '<div class="lb-bar-wrap"><div class="lb-bar" style="width:'+Math.round(count/max*100)+'%;background:'+aC(name)+'"></div></div>'+
                '<div class="lb-num" style="color:'+aC(name)+'">'+count+'</div>'+
                '</div>';
        }).join('');
    })();

    (function() {
        if (!ORDERS.length) return;
        var ff = sortF(ORDERS.map(function(o){ return o.finishing||'None'; }));
        document.getElementById('fTags').innerHTML = ff.map(function(entry,i){ var c=PAL[i%PAL.length]; return '<span class="ftag" style="color:'+c+';border-color:'+c+'55;background:'+c+'18">'+entry[0]+'</span>'; }).join('');
        new Chart(document.getElementById('cFinishing'), {
            type:'bar',
            data:{ labels:ff.map(function(e){return e[0];}), datasets:[{ data:ff.map(function(e){return e[1];}), backgroundColor:ff.map(function(_,i){return PAL[i%PAL.length]+'cc';}), borderRadius:8, borderSkipped:false }] },
            options:{ indexAxis:'y', responsive:true, plugins:{ legend:{display:false}, tooltip:Object.assign({},TT,{callbacks:{label:function(c){return c.raw+' orders';}}}) }, scales:{ x:{grid:{color:'rgba(155,111,212,0.08)'},border:{color:'rgba(155,111,212,0.08)'},ticks:{stepSize:1}}, y:{grid:{display:false},border:{display:false}} } }
        });
    })();

    (function() {
        if (!CUSTOMERS.length) return;
        var top5  = CUSTOMERS.slice(0,5);
        var names = top5.map(function(c){ return c.name.split(' ')[0]; });
        var vals  = top5.map(function(c){ return c.orders.length; });
        new Chart(document.getElementById('cTop5'), {
            type:'bar',
            data:{ labels:names, datasets:[{ label:'Orders', data:vals, backgroundColor:top5.map(function(_,i){ return PAL[i%PAL.length]+'cc'; }), borderRadius:10, borderSkipped:false }] },
            options:{ responsive:true, plugins:{ legend:{display:false}, tooltip:Object.assign({},TT,{ callbacks:{ title:function(items){ return top5[items[0].dataIndex].name; }, label:function(c){ return c.raw+' order'+(c.raw>1?'s':''); } } }) }, scales:{ x:{grid:{display:false},border:{color:'rgba(155,111,212,0.08)'}}, y:{grid:{color:'rgba(155,111,212,0.08)'},border:{color:'rgba(155,111,212,0.08)'},ticks:{stepSize:1}} } }
        });
    })();

    (function() {
        if (!CUSTOMERS.length) return;
        var avgOrders = (ORDERS.length/CUSTOMERS.length).toFixed(1);
        var repeatCust = CUSTOMERS.filter(function(c){ return c.orders.length > 1; }).length;
        document.getElementById('custStats').innerHTML =
            '<div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-top:4px;">'+
                statBox('Most Active',CUSTOMERS[0].name.split(' ')[0],CUSTOMERS[0].orders.length+' orders','#e06fa0')+
                statBox('Avg / Customer',avgOrders,'per unique customer','#9b6fd4')+
                statBox('Repeat Customers',repeatCust,'placed 2+ orders','#5dab8a')+
                statBox('Single-Order',CUSTOMERS.length-repeatCust,'placed 1 order only','#93c5e8')+
            '</div>';
    })();

    function statBox(label,val,sub,color){
        return '<div style="background:rgba(255,255,255,0.5);border:1px solid rgba(255,255,255,0.7);border-radius:14px;padding:16px;box-shadow:0 4px 16px rgba(130,80,180,0.08);">'+
            '<div style="font-size:10px;text-transform:uppercase;letter-spacing:1.5px;color:var(--muted);margin-bottom:6px;font-weight:600;">'+label+'</div>'+
            '<div style="font-family:Playfair Display,serif;font-size:28px;color:'+color+';line-height:1;font-weight:700;">'+val+'</div>'+
            '<div style="font-size:11px;color:var(--muted);margin-top:4px;">'+sub+'</div>'+
            '</div>';
    }

    var ALL_CUSTOMERS = CUSTOMERS;
    function renderCustomerRow(cust,rank){
        var rankClass=rank===1?'rank-1':rank===2?'rank-2':rank===3?'rank-3':'rank-n';
        var services=Object.keys(cust.services).join(', ')||'—';
        var orderNos=cust.orders.map(function(o){ return '<span class="order-tag">'+o.order_no+'</span>'; }).join('');
        var latestDate=cust.orders.reduce(function(latest,o){ var d=new Date(o.created_at); return d>latest?d:latest; },new Date(0));
        var latestStr=isNaN(latestDate)?'—':latestDate.toLocaleDateString('en-GB',{day:'2-digit',month:'short',year:'numeric'});
        return '<tr data-cs="'+(cust.name+' '+cust.phone).toLowerCase()+'">'+
            '<td><span class="rank-badge '+rankClass+'">'+rank+'</span></td>'+
            '<td><div class="cn" style="display:flex;align-items:center;gap:9px;">'+
                '<span style="width:30px;height:30px;border-radius:10px;background:linear-gradient(135deg,'+aC(cust.name)+','+PAL[(rank)%PAL.length]+');color:#fff;display:inline-flex;align-items:center;justify-content:center;font-weight:700;font-size:12px;flex-shrink:0;">'+((cust.name[0]||'?').toUpperCase())+'</span>'+
                cust.name+'</div></td>'+
            '<td class="dim">'+cust.phone+'</td>'+
            '<td><span style="font-family:Playfair Display,serif;font-size:22px;color:'+PAL[(rank-1)%PAL.length]+';font-weight:700;">'+cust.orders.length+'</span></td>'+
            '<td class="dim">'+services+'</td>'+
            '<td><div class="cust-orders">'+orderNos+'</div></td>'+
            '<td class="dim">'+latestStr+'</td>'+
            '</tr>';
    }
    function buildCustomerTable(customers){
        document.getElementById('custCount').textContent='('+customers.length+' of '+CUSTOMERS.length+')';
        document.getElementById('custBody').innerHTML=customers.map(function(cust,i){ return renderCustomerRow(cust,i+1); }).join('');
    }
    buildCustomerTable(CUSTOMERS);
    function filterCustomers(){
        var q=document.getElementById('custSearch').value.toLowerCase();
        buildCustomerTable(!q?CUSTOMERS:CUSTOMERS.filter(function(c){ return (c.name+' '+c.phone).toLowerCase().indexOf(q)!==-1; }));
    }

    function filterTable(){
        var q=document.getElementById('srchInput').value.toLowerCase();
        var rows=document.querySelectorAll('#tBody tr'); var visible=0;
        rows.forEach(function(row){ var show=!q||row.dataset.s.indexOf(q)!==-1; row.style.display=show?'':'none'; if(show)visible++; });
        document.getElementById('tCount').textContent='('+visible+' of '+ORDERS.length+')';
    }

    function escCSV(val){ var s=String(val===null||val===undefined?'':val); if(s.indexOf(',')!==-1||s.indexOf('"')!==-1||s.indexOf('\n')!==-1){s='"'+s.replace(/"/g,'""')+'"';} return s; }
    function downloadCSV(filename,rows){ var csv=rows.map(function(row){return row.map(escCSV).join(',');}).join('\n'); var blob=new Blob(['\uFEFF'+csv],{type:'text/csv;charset=utf-8;'}); var url=URL.createObjectURL(blob); var a=document.createElement('a'); a.href=url; a.download=filename; document.body.appendChild(a); a.click(); document.body.removeChild(a); URL.revokeObjectURL(url); }

    function exportOrdersCSV(){
        var header=['Order No','Client Name','Phone','Service','Product','Quantity','Paper','Finishing','Deadline','Delivery','Sender','Notes','PDF Link','Created At'];
        var rows=[header];
        ORDERS.forEach(function(o){ rows.push([o.order_no,o.client_name,o.phone,o.service,o.product,o.quantity,o.paper,o.finishing,o.deadline,o.delivery,o.send,o.notes,o.pdf_link,o.created_at]); });
        downloadCSV('orders_export_'+today()+'.csv',rows);
    }
    function exportCustomerCSV(){
        var header=['Rank','Customer Name','Phone','Total Orders','Order Numbers','Services Used','Latest Order','Repeat Customer'];
        var rows=[header];
        CUSTOMERS.forEach(function(cust,i){
            var orderNos=cust.orders.map(function(o){return o.order_no;}).join(' | ');
            var services=Object.keys(cust.services).join(' | ');
            var latestDate=cust.orders.reduce(function(latest,o){var d=new Date(o.created_at);return d>latest?d:latest;},new Date(0));
            var latestStr=isNaN(latestDate)?'':latestDate.toLocaleDateString('en-GB');
            rows.push([i+1,cust.name,cust.phone,cust.orders.length,orderNos,services,latestStr,cust.orders.length>1?'Yes':'No']);
        });
        downloadCSV('customer_report_'+today()+'.csv',rows);
    }
    function today(){ return new Date().toISOString().slice(0,10).replace(/-/g,''); }
</script>
</body>
</html>
