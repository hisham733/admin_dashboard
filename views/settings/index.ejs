<div class="section-header">
  <div>
    <h1 class="page-title">System Settings</h1>
    <p class="page-subtitle">Configure logo, organization name, and color scheme.</p>
  </div>
</div>

<% if (typeof error !== 'undefined' && error) { %>
  <div class="card" style="margin-bottom: 20px; border-color: var(--error);">
    <div class="card-body" style="color: var(--error);"><%= error %></div>
  </div>
<% } %>

<div class="card">
  <div class="card-header">
    <div class="card-title">Appearance & Branding</div>
  </div>
  <div class="card-body">
    <form action="/settings" method="POST">
      <div style="display: grid; gap: 24px; max-width: 560px;">
        <div class="form-group">
          <label class="form-label">Organization Name</label>
          <input type="text" name="organization_name" class="form-input" 
            value="<%= settings.organization_name || '' %>" 
            placeholder="e.g. Acme Corp">
        </div>
        <div class="form-group">
          <label class="form-label">System Name (shown in header/sidebar)</label>
          <input type="text" name="system_name" class="form-input" 
            value="<%= settings.system_name || '' %>" 
            placeholder="e.g. Admin Console" required>
        </div>
        <div class="form-group">
          <label class="form-label">Logo URL</label>
          <input type="url" name="logo_url" class="form-input" 
            value="<%= settings.logo_url || '' %>" 
            placeholder="https://example.com/logo.png">
          <small style="font-size: 12px; color: var(--text-muted); margin-top: 4px; display: block;">Leave empty to use default icon</small>
        </div>
        <div class="form-group">
          <label class="form-label">Primary Color (hex)</label>
          <div style="display: flex; gap: 12px; align-items: center;">
            <input type="color" name="primary_color_visual" id="primaryColorPicker" 
              value="<%= settings.primary_color || '#2563eb' %>"
              style="width: 48px; height: 48px; padding: 2px; border: 1px solid var(--border-default); border-radius: var(--radius-md); cursor: pointer;">
            <input type="text" name="primary_color" id="primaryColorInput" class="form-input" 
              value="<%= settings.primary_color || '#2563eb' %>" 
              placeholder="#2563eb" style="flex: 1;">
          </div>
        </div>
        <div class="form-group">
          <label class="form-label">Default Theme (for new sessions)</label>
          <select name="default_theme" class="form-input form-select" style="max-width: 200px;">
            <option value="light" <%= (settings.default_theme || 'light') === 'light' ? 'selected' : '' %>>Light</option>
            <option value="dark" <%= settings.default_theme === 'dark' ? 'selected' : '' %>>Dark</option>
            <option value="system" <%= settings.default_theme === 'system' ? 'selected' : '' %>>System</option>
          </select>
        </div>
        <div style="display: flex; gap: 12px; margin-top: 8px;">
          <button type="submit" class="btn btn-primary">Save Settings</button>
          <a href="/dashboard" class="btn btn-secondary">Cancel</a>
        </div>
      </div>
    </form>
  </div>
</div>

<script>
(function() {
  var picker = document.getElementById('primaryColorPicker');
  var input = document.getElementById('primaryColorInput');
  if (picker && input) {
    picker.addEventListener('input', function() { input.value = picker.value; });
    input.addEventListener('input', function() {
      if (/^#[0-9A-Fa-f]{6}$/.test(input.value)) picker.value = input.value;
    });
  }
})();
</script>
