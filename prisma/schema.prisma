generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Permission {
  id    Int    @id @default(autoincrement())
  name  String @unique @db.VarChar(100)

  roles Role[] @relation("RolePermissions")

  @@map("permissions")
}

model Role {
  id          Int          @id @default(autoincrement())
  name        String       @unique @db.VarChar(100)

  users       User[]
  permissions  Permission[] @relation("RolePermissions")

  @@map("roles")
}

model User {
  id       Int    @id @default(autoincrement())
  name     String @db.VarChar(100)
  email    String @unique
  password  String
  role     Role?  @relation(fields: [roleId], references: [id])
  roleId   Int?   

  forms     FormTemplate[]

  createdAt DateTime @default(now())

  @@map("users")
}

model SystemSetting {
  id        Int      @id @default(autoincrement())
  key       String   @unique @db.VarChar(100)
  value     String?  @db.Text
  updatedAt DateTime @updatedAt

  @@map("system_settings")
}

model FormTemplate {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(200)
  fields      Json?
  isActive    Boolean  @default(false)
  createdBy   User?    @relation(fields: [createdById], references: [id])
  createdById Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("form_templates")
}

model Order {
  id          Int       @id @default(autoincrement())
  order_no    String?   @db.VarChar(50)
  client_name String?   @db.VarChar(100)
  phone       String?   @db.VarChar(50)
  service     String?   @db.VarChar(100)
  product     String?   @db.VarChar(100)
  quantity    String?   @db.VarChar(50)
  paper       String?   @db.VarChar(100)
  finishing   String?   @db.VarChar(100)
  deadline    String?   @db.VarChar(100)
  delivery    String?   @db.VarChar(100)
  notes       String?   @db.Text
  pdf_link    String?   @db.Text
  status      String?   @db.VarChar(50)
  created_at  DateTime? @default(now())

  @@map("orders")
}